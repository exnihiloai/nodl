# Copy this file to .env for local overrides.
# Docker Compose and Rails both provide sensible defaults for local development.

# PostgreSQL
POSTGRES_USER=nodl
POSTGRES_DB=nodl_development
POSTGRES_DB_TEST=nodl_test
POSTGRES_PASSWORD=nodl_local_dev_change_me

# Rails production database password
NODL_DATABASE_PASSWORD=

# Stripe placeholder checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRODUCT_NAME=Nodl Starter Plan
STRIPE_DEFAULT_AMOUNT=1900
STRIPE_CURRENCY=usd

# Mistral Voxtral transcription
MISTRAL_API_KEY=
NODL_VOXTRAL_MODEL=
NODL_VOXTRAL_REALTIME_MODEL=
NODL_VOXTRAL_REALTIME_FAST_DELAY_MS=
NODL_VOXTRAL_REALTIME_SLOW_DELAY_MS=

# Gemini document transformation
GEMINI_API_KEY=
NODL_GEMINI_TRANSFORMER_MODEL=

# OpenTelemetry export
OTEL_SERVICE_NAME=nodl
OTEL_INGEST_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=

# Demo seeds
ALLOW_DEMO_SEEDS=

# Deployment (used by `make deploy`; operators keep these in private/.env)
# DEPLOY_IMAGE: registry image to build & push, e.g. youruser/nodl
# DOKPLOY_DEPLOYMENT_HOOK: Dokploy "redeploy" webhook URL for the app
DEPLOY_IMAGE=
DOKPLOY_DEPLOYMENT_HOOK=
