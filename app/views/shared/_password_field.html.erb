<%# locals: (f:, field:, **) %>
<%
  html_options = local_assigns.except(:f, :field)
  input_classes = [ html_options.delete(:class), "pr-12" ].compact.join(" ")
  data_attrs = (html_options.delete(:data) || {}).merge(password_visibility_target: "input")
%>
<div class="relative"
     data-controller="password-visibility"
     data-password-visibility-show-label-value="<%= t("shared.password_field.show") %>"
     data-password-visibility-hide-label-value="<%= t("shared.password_field.hide") %>">
  <%= f.password_field field, html_options.merge(class: input_classes, data: data_attrs) %>
  <div class="absolute inset-y-0 right-1 z-10 flex items-center">
    <button type="button"
            class="btn btn-ghost btn-sm btn-square min-h-0 h-10 w-10"
            data-action="password-visibility#toggle"
            aria-label="<%= t("shared.password_field.show") %>"
            aria-pressed="false">
      <span data-password-visibility-target="hiddenIcon"><%= icon "eye", class: "size-5" %></span>
      <span data-password-visibility-target="visibleIcon" class="hidden"><%= icon "eye-off", class: "size-5" %></span>
    </button>
  </div>
</div>
