<header class="border-b border-base-300 bg-base-100/90 backdrop-blur sticky top-0 z-40">
  <div class="container mx-auto px-4">
    <div class="navbar px-0">
      <div class="navbar-start">
        <%= link_to dashboard_path, class: "btn btn-ghost normal-case text-xl font-semibold gap-2 px-2", data: { testid: "nav-logo" } do %>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl border border-base-300/70 bg-base-200 text-base-content"><%= icon("nodl-mark", class: "w-7 h-4") %></span>
          Nodl
        <% end %>
      </div>
      <div class="navbar-end flex items-center gap-2">
        <%= render "shared/theme_toggle" %>

        <ul class="menu menu-horizontal hidden px-1 lg:flex">
          <li><%= link_to t("nav.dashboard"), dashboard_path, class: "rounded-btn", data: { testid: "nav-dashboard" } %></li>
          <% if current_user&.admin? %>
            <li><%= link_to t("nav.admin"), admin_users_path, class: "rounded-btn" %></li>
          <% end %>
        </ul>

        <details class="dropdown dropdown-end" data-controller="dropdown">
          <summary class="btn btn-ghost gap-2 list-none" data-testid="account-menu">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">
              <%= current_user.email.to_s[0]&.upcase %>
            </span>
            <span class="hidden min-w-0 max-w-[12rem] truncate text-sm sm:inline" title="<%= current_user.email %>"><%= current_user.email %></span>
          </summary>
          <div class="dropdown-content z-50 mt-2 w-72 max-w-[calc(100vw-2rem)] rounded-box border border-base-300 bg-base-100 p-2 shadow-lg overflow-hidden">
            <div class="flex items-start gap-2 px-3 py-2 min-w-0">
              <%= icon("user", class: "size-4 mt-0.5 shrink-0 text-base-content/50", label: t("nav.account.signed_in_as")) %>
              <div class="min-w-0 flex-1">
                <p class="text-xs text-base-content/50"><%= t("nav.account.signed_in_as") %></p>
                <p class="truncate text-sm font-medium" title="<%= current_user.email %>"><%= current_user.email %></p>
              </div>
            </div>

            <% account_workspaces = current_user.memberships.includes(:workspace).order(:created_at).map(&:workspace) %>
            <% if account_workspaces.any? %>
              <div class="divider my-1"></div>
              <p class="flex items-center gap-1.5 px-3 py-1 text-xs text-base-content/50">
                <%= icon("building-2", class: "size-3.5 shrink-0", label: t("nav.account.workspace")) %>
                <%= t("nav.account.workspace") %>
              </p>
              <ul class="menu menu-sm w-full">
                <% account_workspaces.each do |workspace| %>
                  <% is_current = workspace == current_workspace %>
                  <li class="p-0">
                    <%= button_to switch_workspace_path(workspace),
                                  method: :post,
                                  form_class: "w-full min-w-0 flex !p-0",
                                  form: { data: { turbo: false } },
                                  class: ["flex w-full min-w-0 items-center justify-between gap-3 overflow-hidden px-2.5 py-1 rounded-[inherit]", ("active" if is_current)].compact.join(" ") do %>
                      <span class="flex min-w-0 flex-1 items-center gap-2 overflow-hidden">
                        <%= icon("building-2", class: "size-4 shrink-0 text-base-content/60", label: workspace_display_name(workspace)) %>
                        <span class="truncate" title="<%= workspace_display_name(workspace) %>"><%= workspace_display_name(workspace) %></span>
                      </span>
                      <% if is_current %>
                        <span class="badge badge-primary badge-sm shrink-0"><%= t("nav.account.current") %></span>
                      <% end %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% end %>

            <div class="divider my-1"></div>
            <p class="flex items-center gap-1.5 px-3 py-1 text-xs text-base-content/50">
              <%= icon("languages", class: "size-3.5 shrink-0", label: t("language_switcher.label")) %>
              <%= t("language_switcher.label") %>
            </p>
            <ul class="menu menu-sm w-full" data-testid="language-switcher">
              <% I18n.available_locales.each do |locale| %>
                <li class="p-0">
                  <%= button_to locale_path(locale: locale),
                                method: :patch,
                                form_class: "w-full flex !p-0",
                                form: { data: { turbo: false } },
                                class: ["flex w-full items-center justify-between gap-3 px-2.5 py-1 rounded-[inherit]", ("active" if I18n.locale == locale)].compact.join(" "),
                                data: { testid: "language-option-#{locale}" } do %>
                    <span><%= t("language_switcher.languages.#{locale}") %></span>
                    <% if I18n.locale == locale %>
                      <%= icon("check", class: "size-4") %>
                    <% end %>
                  <% end %>
                </li>
              <% end %>
            </ul>

            <div class="divider my-1"></div>
            <ul class="menu menu-sm w-full">
              <li>
                <%= link_to settings_path, class: "flex items-center gap-2", data: { testid: "settings-link" } do %>
                  <%= icon("settings", class: "size-4 shrink-0", label: t("nav.account.settings")) %>
                  <%= t("nav.account.settings") %>
                <% end %>
              </li>
              <li>
                <%= link_to payments_path, class: "flex items-center gap-2" do %>
                  <%= icon("sparkles", class: "size-4 shrink-0", label: t("nav.account.upgrade_plan")) %>
                  <%= t("nav.account.upgrade_plan") %>
                <% end %>
              </li>
              <li class="p-0">
                <%= button_to logout_path,
                              method: :post,
                              form_class: "w-full flex !p-0",
                              form: { data: { turbo: false } },
                              class: "flex w-full items-center gap-2 justify-start px-2.5 py-1 rounded-[inherit]",
                              data: { testid: "logout-btn-desktop" } do %>
                  <%= icon("log-out", class: "size-4 shrink-0", label: t("nav.account.log_out")) %>
                  <%= t("nav.account.log_out") %>
                <% end %>
              </li>
            </ul>
          </div>
        </details>
      </div>
    </div>
  </div>
</header>
