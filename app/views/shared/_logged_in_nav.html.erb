<header class="border-b border-base-300 bg-base-100/90 backdrop-blur sticky top-0 z-40">
  <div class="container mx-auto px-4">
    <div class="navbar px-0">
      <div class="navbar-start">
        <%= link_to "Nodl", dashboard_path, class: "btn btn-ghost normal-case text-xl font-semibold", data: { testid: "nav-logo" } %>
      </div>
      <div class="navbar-end flex items-center gap-2">
        <%= render "shared/theme_toggle" %>

        <ul class="menu menu-horizontal hidden px-1 lg:flex">
          <li><%= link_to t("nav.dashboard"), dashboard_path, class: "rounded-btn", data: { testid: "nav-dashboard" } %></li>
          <% if current_user&.admin? %>
            <li><%= link_to t("nav.admin"), admin_users_path, class: "rounded-btn" %></li>
          <% end %>
        </ul>

        <div class="dropdown dropdown-end">
          <div tabindex="0" role="button" class="btn btn-ghost gap-2" data-testid="account-menu">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">
              <%= current_user.email.to_s[0]&.upcase %>
            </span>
            <span class="hidden max-w-[12rem] truncate text-sm sm:inline"><%= current_user.email %></span>
          </div>
          <div tabindex="0" class="dropdown-content z-50 mt-2 w-72 rounded-box border border-base-300 bg-base-100 p-2 shadow-lg">
            <div class="px-3 py-2">
              <p class="text-xs text-base-content/50"><%= t("nav.account.signed_in_as") %></p>
              <p class="truncate text-sm font-medium"><%= current_user.email %></p>
            </div>

            <% account_workspaces = current_user.memberships.includes(:workspace).order(:created_at).map(&:workspace) %>
            <% if account_workspaces.any? %>
              <div class="divider my-1"></div>
              <p class="px-3 py-1 text-xs text-base-content/50"><%= t("nav.account.workspace") %></p>
              <ul class="menu menu-sm w-full">
                <% account_workspaces.each do |workspace| %>
                  <% is_current = workspace == current_workspace %>
                  <li>
                    <%= button_to switch_workspace_path(workspace),
                                  method: :post,
                                  form_class: "w-full",
                                  class: ["flex w-full items-center justify-between gap-3", ("active" if is_current)].compact.join(" ") do %>
                      <span class="truncate"><%= workspace.name %></span>
                      <% if is_current %>
                        <span class="badge badge-primary badge-sm shrink-0"><%= t("nav.account.current") %></span>
                      <% end %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% end %>

            <div class="divider my-1"></div>
            <p class="px-3 py-1 text-xs text-base-content/50"><%= t("language_switcher.label") %></p>
            <ul class="menu menu-sm w-full" data-testid="language-switcher">
              <% I18n.available_locales.each do |locale| %>
                <li>
                  <%= button_to locale_path(locale: locale),
                                method: :patch,
                                form_class: "w-full",
                                class: ["flex w-full items-center justify-between gap-3", ("active" if I18n.locale == locale)].compact.join(" "),
                                data: { testid: "language-option-#{locale}" } do %>
                    <span><%= t("language_switcher.languages.#{locale}") %></span>
                    <% if I18n.locale == locale %>
                      <%= icon("check", class: "size-4") %>
                    <% end %>
                  <% end %>
                </li>
              <% end %>
            </ul>

            <div class="divider my-1"></div>
            <ul class="menu menu-sm w-full">
              <li><%= link_to t("nav.account.upgrade_plan"), payments_path %></li>
              <li><%= button_to t("nav.account.log_out"), logout_path, method: :post, class: "w-full justify-start", data: { testid: "logout-btn-desktop" } %></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
