<%# Flag-free language switcher: languages are listed by their endonym
    ("English", "Deutsch"). Persists the choice via LocalesController. %>
<div class="dropdown dropdown-end" data-testid="language-switcher">
  <div tabindex="0" role="button" class="btn btn-ghost btn-sm gap-1" aria-label="<%= t("language_switcher.label") %>">
    <%= icon("languages", class: "size-4") %>
    <span class="text-sm font-medium uppercase"><%= I18n.locale %></span>
  </div>
  <ul tabindex="0" class="dropdown-content menu z-50 mt-2 w-40 rounded-box border border-base-300 bg-base-100 p-1 shadow-lg">
    <% I18n.available_locales.each do |locale| %>
      <li>
        <%= button_to locale_path(locale: locale),
                      method: :patch,
                      form_class: "w-full",
                      class: ["flex w-full items-center justify-between", ("active" if I18n.locale == locale)].compact.join(" "),
                      data: { testid: "language-option-#{locale}" } do %>
          <span><%= t("language_switcher.languages.#{locale}") %></span>
          <% if I18n.locale == locale %>
            <%= icon("check", class: "size-4") %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
