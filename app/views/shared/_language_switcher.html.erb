<%# Flag-free language switcher: languages are listed by their endonym
    ("English", "Deutsch"). Persists the choice via LocalesController. %>
<details class="dropdown dropdown-end" data-testid="language-switcher" data-controller="dropdown">
  <summary class="btn btn-ghost btn-sm gap-1 list-none" aria-label="<%= t("language_switcher.label") %>">
    <%= icon("languages", class: "size-4") %>
    <span class="text-sm font-medium uppercase"><%= I18n.locale %></span>
  </summary>
  <ul class="dropdown-content menu z-50 mt-2 w-40 rounded-box border border-base-300 bg-base-100 p-1 shadow-lg">
    <% I18n.available_locales.each do |locale| %>
      <li class="p-0">
        <%= button_to locale_path(locale: locale),
                      method: :patch,
                      form_class: "w-full flex !p-0",
                      form: { data: { turbo: false } },
                      class: ["flex w-full items-center justify-between px-3 py-1.5 rounded-[inherit]", ("active" if I18n.locale == locale)].compact.join(" "),
                      data: { testid: "language-option-#{locale}" } do %>
          <span><%= t("language_switcher.languages.#{locale}") %></span>
          <% if I18n.locale == locale %>
            <%= icon("check", class: "size-4") %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ul>
</details>
