<div id="live_transcript_status">
  <div class="flex items-center justify-between gap-3">
    <h2 class="text-sm font-semibold">Transcript</h2>
    <% if recording_session.recording? %>
      <span class="badge badge-warning badge-sm">Preview</span>
    <% elsif recording_session.completed? %>
      <span class="badge badge-success badge-sm">Final</span>
    <% elsif recording_session.failed? %>
      <span class="badge badge-error badge-sm">Failed</span>
    <% end %>
  </div>

  <% if recording_session.failed? %>
    <p class="mt-1 text-xs text-error"><%= recording_session.error_message.presence || "Final transcription failed." %></p>
  <% end %>
</div>
