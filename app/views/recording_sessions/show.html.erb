<% content_for :title, "#{@recording_session.title} - Nodl" %>

<% segments = @recording_session.transcript_segments %>
<% has_player = @recording_session.completed? && @recording_session.playback_audio.attached? %>

<section class="bg-base-200 py-10">
  <div class="container mx-auto px-4 max-w-5xl space-y-6"
       data-controller="audio-player"
       <% if has_player %>
         data-audio-player-audio-url-value="<%= rails_blob_path(@recording_session.playback_audio) %>"
         data-audio-player-multi-speaker-value="<%= multi_speaker_transcript?(segments) %>"
         data-audio-player-colors-value="<%= speaker_color_map(segments).to_json %>"
         data-audio-player-timeline-value="<%= transcript_timeline(segments).to_json %>"
         data-audio-player-peaks-value="<%= (@recording_session.waveform_peaks || []).to_json %>"
         data-audio-player-duration-value="<%= @recording_session.audio_duration.to_f %>"
       <% end %>>
    <%= turbo_stream_from @recording_session, :live if @recording_session.recording? || @recording_session.processing? %>

    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <%= link_to t("recording_sessions.show.back_to_dashboard"), dashboard_path, class: "link link-hover text-sm" %>
        <h1 class="mt-2 text-3xl font-bold"><%= @recording_session.title %></h1>
        <p class="text-base-content/70"><%= t("recording_sessions.show.format", name: @recording_session.transformer_handle.humanize) %></p>
      </div>
      <% if !@recording_session.completed? || !@recording_session.recording? %>
        <div class="flex flex-col items-start gap-2 sm:items-end">
          <% unless @recording_session.completed? %>
          <span class="badge badge-lg <%= @recording_session.failed? ? "badge-error" : "badge-warning" %>"><%= t("recording_sessions.statuses.#{@recording_session.status}") %></span>
          <% end %>
          <% unless @recording_session.recording? %>
            <details class="dropdown dropdown-end" data-controller="dropdown" data-testid="recording-actions-menu">
              <summary class="btn btn-ghost btn-circle btn-sm list-none text-primary/70 hover:bg-primary/10 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                       data-testid="recording-actions-menu-button"
                       aria-label="<%= t("recording_sessions.actions.menu") %>">
                <%= icon("ellipsis", class: "size-5") %>
              </summary>
              <ul class="dropdown-content menu z-10 mt-2 w-40 rounded-box border border-base-300 bg-base-100 p-1 shadow">
                <li class="p-0">
                  <%= render "recording_sessions/delete_button",
                             recording_session: @recording_session,
                             params: { redirect_to_dashboard: true },
                             data: { testid: "recording-delete-button" } %>
                </li>
              </ul>
            </details>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @recording_session.failed? %>
      <div class="alert alert-error">
        <span><%= @recording_session.error_message %></span>
      </div>
    <% end %>

    <% if @recording_session.creator.integrity_sealing_enabled? %>
      <% integrity_record = @recording_session.integrity_record %>
      <% integrity_panel_id = "integrity-status-panel-#{@recording_session.id}" %>
      <div class="integrity-status rounded-box border border-base-300 bg-base-100 shadow-sm"
           data-controller="disclosure"
           data-disclosure-open-class="is-open"
           data-testid="integrity-status">
        <button type="button"
                id="<%= integrity_panel_id %>-trigger"
                class="integrity-status-trigger flex w-full cursor-pointer list-none select-none items-center gap-3 rounded-box p-4 text-left transition-colors hover:bg-base-200/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                data-disclosure-target="trigger"
                data-action="disclosure#toggle"
                aria-expanded="false"
                aria-controls="<%= integrity_panel_id %>">
          <span class="flex size-5 shrink-0 items-center justify-center" aria-hidden="true">
            <%= icon("chevron-right", class: "integrity-status-chevron size-4 text-base-content/50") %>
          </span>
          <span class="flex size-5 shrink-0 items-center justify-center text-primary" aria-hidden="true">
            <%= icon("shield-check", class: "size-5") %>
          </span>
          <span class="min-w-0 flex-1 font-semibold"><%= t("recording_sessions.integrity.heading") %></span>
          <% if integrity_record&.sealed? %>
            <span class="integrity-sealed-badge shrink-0" data-testid="integrity-status-badge">
              <span class="integrity-sealed-badge__icon" aria-hidden="true">
                <%= icon("check", class: "size-3") %>
              </span>
              <span class="integrity-sealed-badge__label"><%= t("recording_sessions.integrity.statuses_compact.sealed") %></span>
            </span>
          <% else %>
            <span class="badge <%= integrity_badge_class(integrity_record) %>" data-testid="integrity-status-badge">
              <%= t("recording_sessions.integrity.statuses.#{integrity_status_key(integrity_record)}") %>
            </span>
          <% end %>
        </button>

        <div id="<%= integrity_panel_id %>"
             class="integrity-status-panel"
             data-disclosure-target="panel"
             inert>
          <div class="integrity-status-panel-inner">
            <div class="integrity-status-panel-content flex flex-col gap-3 border-t border-base-300 px-4 pb-4 pt-3 sm:flex-row sm:items-center sm:justify-between" data-testid="integrity-status-details">
              <p class="text-sm text-base-content/70">
                <% if integrity_record&.sealed? && integrity_record.tsa_timestamp.present? %>
                  <%= t("recording_sessions.integrity.sealed_at", time: l(integrity_record.tsa_timestamp.utc, format: :short)) %>
                <% else %>
                  <%= t("recording_sessions.integrity.descriptions.#{integrity_status_key(integrity_record)}") %>
                <% end %>
              </p>
              <% if integrity_record&.sealed? && @recording_session.original_audio_downloadable? %>
                <%= link_to download_integrity_archive_recording_session_path(@recording_session),
                            class: "btn btn-sm gap-2 shrink-0",
                            data: { testid: "download-integrity-archive" } do %>
                  <%= icon("download", class: "size-4") %>
                  <span><%= t("recording_sessions.integrity.download_archive") %></span>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid gap-6 lg:grid-cols-2">
      <section class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm" data-controller="clipboard" data-clipboard-copy-text-value="<%= t("clipboard.copy") %>" data-clipboard-copied-text-value="<%= t("clipboard.copied") %>">
        <div class="flex items-start justify-between gap-2">
          <h2 class="text-xl font-semibold"><%= t("recording_sessions.show.transcript") %></h2>
          <% if @recording_session.completed? && (segments.present? || @recording_session.transcript_text.present?) %>
            <button type="button"
                    class="btn btn-ghost btn-sm gap-2"
                    data-action="clipboard#copy"
                    data-testid="copy-transcript"
                    aria-label="<%= t("recording_sessions.show.copy_transcript") %>">
              <span data-clipboard-target="copyIcon"><%= icon "copy", class: "h-4 w-4" %></span>
              <span data-clipboard-target="checkIcon" class="hidden text-success"><%= icon "check", class: "h-4 w-4" %></span>
              <span data-clipboard-target="label"><%= t("recording_sessions.show.copy") %></span>
            </button>
          <% end %>
        </div>
        <% if @recording_session.recording? || @recording_session.processing? %>
          <div class="mt-4">
            <%= render "recording_sessions/live_transcript_panel",
                       recording_session: @recording_session %>
          </div>
        <% elsif @recording_session.completed? && segments.present? %>
          <div class="mt-4 max-h-96 overflow-y-auto rounded-box bg-base-200 p-4">
            <%= render "recording_sessions/interactive_transcript", segments: segments %>
          </div>
        <% elsif @recording_session.transcript_text.present? %>
          <div class="mt-4 whitespace-pre-wrap rounded-box bg-base-200 p-4 text-sm leading-6 text-base-content" data-clipboard-target="source"><%= @recording_session.transcript_text %></div>
        <% else %>
          <p class="mt-4 text-base-content/70"><%= t("recording_sessions.show.transcript_unavailable") %></p>
        <% end %>
      </section>

      <section class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm">
        <h2 class="text-xl font-semibold"><%= t("recording_sessions.show.document") %></h2>
        <% if @document %>
          <p class="mt-2 text-sm text-base-content/70"><%= t("recording_sessions.show.generated_at", time: l(@document.local_generated_at, format: :short)) %></p>
          <%= link_to t("recording_sessions.show.open_document"), document_path(@document), class: "btn btn-primary mt-4" %>
        <% else %>
          <p class="mt-4 text-base-content/70"><%= t("recording_sessions.show.document_not_finished") %></p>
        <% end %>
      </section>
    </div>

    <% if has_player %>
      <section class="rounded-box border border-base-300 bg-base-100 p-4 shadow-sm" data-testid="audio-player">
        <audio data-audio-player-target="audio" preload="metadata" src="<%= rails_blob_path(@recording_session.playback_audio) %>"></audio>

        <div class="flex items-center gap-4">
          <button type="button"
                  class="btn btn-primary btn-circle shrink-0"
                  data-audio-player-target="playButton"
                  data-action="audio-player#togglePlay"
                  aria-label="<%= t("recording_sessions.show.play_pause") %>">
            <span data-audio-player-target="playIcon"><%= icon("play", class: "size-5") %></span>
            <span data-audio-player-target="pauseIcon" class="hidden"><%= icon("pause", class: "size-5") %></span>
          </button>

          <div class="min-w-0 flex-1">
            <canvas class="h-16 w-full cursor-pointer"
                    data-audio-player-target="waveform"
                    data-action="click->audio-player#scrub"></canvas>
            <div class="mt-1 flex justify-between font-mono text-xs text-base-content/60">
              <span data-audio-player-target="currentTime">0:00</span>
              <span data-audio-player-target="duration">0:00</span>
            </div>
          </div>

          <label class="flex shrink-0 items-center gap-2 text-primary/70" aria-label="<%= t("recording_sessions.show.volume") %>">
            <%= icon("volume-2", class: "size-4") %>
            <input type="range" min="0" max="1" step="0.01" value="1"
                   class="range range-primary range-xs w-24"
                   data-audio-player-target="volume"
                   data-action="input->audio-player#setVolume">
          </label>

          <% if @recording_session.original_audio_downloadable? %>
            <details class="dropdown dropdown-end shrink-0" data-controller="dropdown" data-testid="audio-actions-menu">
              <summary class="btn btn-ghost btn-circle btn-sm list-none text-primary/70 hover:bg-primary/10 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                       data-testid="audio-actions-menu-button"
                       aria-label="<%= t("recording_sessions.show.audio_actions") %>">
                <%= icon("ellipsis", class: "size-5") %>
              </summary>
              <ul class="dropdown-content menu z-10 mt-2 w-64 rounded-box border border-base-300 bg-base-100 p-1 shadow">
                <li>
                  <%= link_to download_original_audio_recording_session_path(@recording_session),
                              class: "flex items-center gap-2",
                              data: { testid: "download-original-audio" } do %>
                    <%= icon("download", class: "size-4") %>
                    <span><%= t("recording_sessions.show.download_original_audio") %></span>
                  <% end %>
                </li>
                <% if @recording_session.creator.integrity_sealing_enabled? && @recording_session.integrity_record&.sealed? %>
                  <li>
                    <%= link_to download_integrity_archive_recording_session_path(@recording_session),
                                class: "flex items-center gap-2",
                                data: { testid: "download-integrity-archive-menu" } do %>
                      <%= icon("shield-check", class: "size-4") %>
                      <span><%= t("recording_sessions.integrity.download_archive") %></span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </details>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</section>
