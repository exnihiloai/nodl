<% content_for :title, "Plans and Checkout" %>
<% content_for :head do %>
  <meta name="description" content="Choose your plan and checkout with Stripe." />
<% end %>

<section class="bg-gradient-to-br from-base-200 via-base-100 to-base-200 py-20">
  <div class="container mx-auto px-4 max-w-4xl space-y-10">
    <header class="text-center space-y-3">
      <span class="badge badge-primary badge-lg">Payments preview</span>
      <h1 class="text-4xl font-semibold">Get ready for Stripe Checkout</h1>
      <p class="text-base-content/70 text-lg">Launch payments quickly with pre-wired Stripe Checkout flows.</p>
    </header>

    <section class="card bg-base-100 shadow-2xl">
      <div class="card-body space-y-6">
        <div class="space-y-2">
          <h2 class="card-title text-2xl"><%= @product_name %></h2>
          <p class="text-base-content/70">
            Charge a one-time payment using Stripe Checkout. Configure prices in Stripe or provide <code class="kbd kbd-sm">STRIPE_PRICE_ID</code>.
          </p>
        </div>
        <div class="rounded-box bg-base-200 p-4 text-sm space-y-1">
          <% if @stripe_price_id.present? %>
            <div class="font-semibold text-base-content">Managed in Stripe</div>
            <div class="text-base-content/70">Using <code class="kbd kbd-xs"><%= @stripe_price_id %></code> for hosted checkout.</div>
          <% else %>
            <div class="font-semibold text-2xl text-base-content"><%= format("%.2f", @amount_cents / 100.0) %> <%= @currency %></div>
            <div class="text-base-content/70">Using test defaults. Update env vars before going live.</div>
          <% end %>
        </div>

        <% if @stripe_configured %>
          <%= form_with url: payments_checkout_path, method: :post, class: "card bg-base-200 border border-base-300" do |f| %>
            <div class="card-body gap-4 flex flex-col sm:flex-row sm:items-center">
              <%= f.submit "Start secure checkout", class: "btn btn-primary btn-lg" %>
              <div class="text-sm text-base-content/70">
                <p>You will be redirected to Stripe's hosted checkout page.</p>
                <p>Test card: <code class="kbd kbd-xs">4242 4242 4242 4242</code></p>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="alert alert-warning flex-col items-start gap-2">
            <span class="font-semibold">Stripe configuration required</span>
            <p class="text-sm">Set these environment variables to enable checkout:</p>
            <div class="bg-base-100 rounded-box p-3 font-mono text-xs">
              STRIPE_SECRET_KEY=sk_test_...<br />
              STRIPE_PUBLISHABLE_KEY=pk_test_...
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="card bg-base-100 shadow">
      <div class="card-body space-y-3">
        <h3 class="card-title text-lg">Test webhooks</h3>
        <p class="text-base-content/70">
          Point Stripe CLI to <code class="kbd kbd-xs">/payments/webhook</code>
          with <code class="kbd kbd-xs">STRIPE_WEBHOOK_SECRET</code>.
        </p>
      </div>
    </section>

    <div class="text-center">
      <%= link_to "← Back to homepage", root_path, class: "link link-hover" %>
    </div>
  </div>
</section>
