<% content_for :title, t("payments.show.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("payments.show.meta_description") %>" />
<% end %>

<section class="bg-base-100 py-12 md:py-16">
  <div class="container mx-auto max-w-6xl px-4">
    <header class="mx-auto max-w-3xl text-center">
      <span class="badge badge-primary badge-lg"><%= t("payments.show.badge") %></span>
      <h1 class="mt-4 text-3xl font-semibold text-base-content md:text-5xl"><%= t("payments.show.heading") %></h1>
      <p class="mt-4 text-base text-base-content/70 md:text-lg"><%= t("payments.show.subheading") %></p>
    </header>

    <div class="mt-8 flex flex-col items-center justify-between gap-4 rounded-box border border-base-300 bg-base-200 p-3 md:flex-row">
      <div class="join">
        <% BillingPriceCatalog::REGIONS.each_key do |region| %>
          <%= link_to t(BillingPriceCatalog::REGIONS.fetch(region).fetch(:label_key)),
                      payments_path(region:, interval: @selected_interval),
                      class: class_names("btn join-item btn-sm", "btn-active": region == @selected_region),
                      data: { testid: "pricing-region-#{region}" } %>
        <% end %>
      </div>

      <div class="join">
        <% BillingPriceCatalog::INTERVALS.each_key do |interval| %>
          <%= link_to t(BillingPriceCatalog::INTERVALS.fetch(interval).fetch(:label_key)),
                      payments_path(region: @selected_region, interval:),
                      class: class_names("btn join-item btn-sm", "btn-active": interval == @selected_interval),
                      data: { testid: "pricing-interval-#{interval}" } %>
        <% end %>
      </div>
    </div>

    <div class="mt-8 grid gap-5 lg:grid-cols-2">
      <% @plan_cards.each do |plan| %>
        <% selected_price = plan.prices.fetch(@selected_interval) %>
        <article class="card border <%= plan.highlight ? "border-primary bg-primary/5 shadow-xl" : "border-base-300 bg-base-100 shadow" %>">
          <div class="card-body gap-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="card-title text-2xl"><%= plan.name %></h2>
                <p class="mt-2 text-sm text-base-content/70"><%= t(plan.description_key) %></p>
              </div>
              <% if plan.highlight %>
                <span class="badge badge-primary"><%= t("payments.show.recommended") %></span>
              <% end %>
            </div>

            <div>
              <div class="flex items-end gap-2">
                <span class="text-4xl font-semibold tracking-normal">
                  <%= number_to_currency(selected_price.amount_cents / 100.0, unit: selected_price.currency == "eur" ? "€" : "$", precision: 0) %>
                </span>
                <span class="pb-1 text-sm text-base-content/60">
                  <%= selected_price.annual? ? t("payments.show.per_year") : t("payments.show.per_month") %>
                </span>
              </div>
              <% if selected_price.annual? %>
                <p class="mt-1 text-sm text-base-content/60">
                  <%= t("payments.show.annual_note") %>
                </p>
              <% end %>
            </div>

            <ul class="space-y-3 text-sm">
              <% plan.features.each do |feature_key| %>
                <li class="flex gap-3">
                  <span class="mt-1 size-2 rounded-full bg-primary"></span>
                  <span><%= t(feature_key) %></span>
                </li>
              <% end %>
            </ul>

            <div class="card-actions mt-auto">
              <% if @stripe_configured %>
                <%= button_to t("payments.show.start_checkout"),
                              payments_checkout_path,
                              method: :post,
                              params: {
                                plan: plan.code,
                                region: @selected_region,
                                interval: @selected_interval
                              },
                              class: "btn btn-primary w-full",
                              form: { data: { turbo: false } },
                              data: { testid: "checkout-#{plan.code}" } %>
              <% else %>
                <button class="btn btn-disabled w-full"><%= t("payments.show.checkout_unavailable") %></button>
              <% end %>
            </div>

            <% unless selected_price.stripe_price_id.present? %>
              <p class="text-xs text-base-content/50">
                <%= t("payments.show.dynamic_price_note") %>
              </p>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>

    <% unless @stripe_configured %>
      <section class="mt-6 rounded-box border border-warning/40 bg-warning/10 p-4">
        <h2 class="font-semibold"><%= t("payments.show.config_required") %></h2>
        <p class="mt-1 text-sm text-base-content/70"><%= t("payments.show.config_hint") %></p>
        <div class="mt-3 rounded-box bg-base-100 p-3 font-mono text-xs">
          STRIPE_SECRET_KEY=sk_test_...
        </div>
      </section>
    <% end %>

    <section class="mt-8 rounded-box border border-base-300 bg-base-200 p-5 text-sm text-base-content/70">
      <p><%= t("payments.show.redirect_note") %></p>
      <p class="mt-1"><%= t("payments.show.monthly_limits_note") %></p>
      <p class="mt-1"><%= t("payments.show.test_card_html", code: content_tag(:code, "4242 4242 4242 4242", class: "kbd kbd-xs")) %></p>
    </section>
  </div>
</section>
