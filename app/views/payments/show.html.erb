<% content_for :title, t("payments.show.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("payments.show.meta_description") %>" />
<% end %>

<%= render "pricing/plan_overview",
      selected_region: @selected_region,
      selected_interval: @selected_interval,
      plan_cards: @plan_cards,
      stripe_configured: @stripe_configured,
      pricing_url: ->(region:, interval:) { payments_path(region:, interval:) },
      show_config_warning: true %>
