<div id="role_section" class="mt-4">
  <label class="label"><%= t("admin.users.role_section.label") %></label>
  <div class="font-medium">
    <% if managed_user.admin? %>
      <span class="badge badge-warning"><%= t("admin.roles.admin") %></span>
    <% else %>
      <span class="badge badge-outline"><%= t("admin.roles.user") %></span>
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="alert alert-success mt-2"><span><%= notice %></span></div>
  <% elsif error.present? %>
    <div class="alert alert-error mt-2"><span><%= error %></span></div>
  <% end %>

  <%= form_with url: update_role_admin_user_path(managed_user), method: :patch, class: "mt-2" do |f| %>
    <%= f.select :role, options_for_select([[t("admin.roles.user"), "user"], [t("admin.roles.admin"), "admin"]], managed_user.role), {}, class: "select select-bordered w-full" %>
    <%= f.submit t("admin.users.role_section.update"), class: "btn btn-sm mt-2" %>
  <% end %>
</div>
