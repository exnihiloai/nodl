<% content_for :title, t("admin.users.show.title") %>

<section class="container mx-auto px-4 py-10">
  <div class="breadcrumbs text-sm mb-4">
    <ul>
      <li><%= link_to t("admin.breadcrumbs.dashboard"), dashboard_path, class: "link" %></li>
      <li><%= link_to t("admin.breadcrumbs.users"), admin_users_path, class: "link" %></li>
      <li><%= @managed_user.email %></li>
    </ul>
  </div>

  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold mb-1"><%= t("admin.users.show.heading", email: @managed_user.email) %></h1>
      <p class="text-base-content/70"><%= t("admin.users.show.id", id: @managed_user.id) %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
    <div class="card bg-base-100 shadow-sm lg:col-span-1">
      <div class="card-body">
        <h2 class="card-title"><%= t("admin.users.show.account_information") %></h2>

        <%= render "admin/users/email_section", managed_user: @managed_user, notice: nil, error: nil %>
        <%= render "admin/users/role_section", managed_user: @managed_user, notice: nil, error: nil %>
        <%= render "admin/users/password_section", managed_user: @managed_user, notice: nil, error: nil, generated_password: nil %>
        <%= render "admin/users/integrity_sealing_section", managed_user: @managed_user, notice: nil, error: nil %>

        <div class="mt-4 space-y-2 text-sm">
          <p><strong><%= t("admin.users.show.created") %></strong> <%= @managed_user.created_at&.strftime("%Y-%m-%d %H:%M") || t("admin.common.none") %></p>
          <p><strong><%= t("admin.users.show.last_login") %></strong> <%= @managed_user.last_login_at&.strftime("%Y-%m-%d %H:%M") || t("admin.common.never") %></p>
        </div>

        <%= render "admin/users/lifecycle_section", managed_user: @managed_user, notice: nil, error: nil %>
      </div>
    </div>

    <div class="card bg-base-100 shadow-sm lg:col-span-2">
      <div class="card-body">
        <h2 class="card-title"><%= t("admin.users.show.subscription_and_usage") %></h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <h3 class="font-semibold"><%= t("admin.users.show.subscription_status") %></h3>
            <% if @workspace.present? %>
              <p class="capitalize"><%= @workspace.subscription_status %></p>
              <p><%= t("admin.users.show.plan_html", plan: content_tag(:span, @workspace.subscription_plan, class: "capitalize")) %></p>
              <p><%= t("admin.users.show.billing_cycle_html", cycle: content_tag(:span, @workspace.subscription_billing_cycle, class: "capitalize")) %></p>
            <% else %>
              <p><%= t("admin.users.show.no_workspace") %></p>
            <% end %>
          </div>

          <%= render "admin/users/usage_section", managed_user: @managed_user, workspace: @workspace, notice: nil, error: nil %>
        </div>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm mt-6">
    <div class="card-body">
      <h2 class="card-title"><%= t("admin.users.show.audit_events") %></h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th><%= t("admin.users.show.col_action") %></th>
              <th><%= t("admin.users.show.col_timestamp") %></th>
              <th><%= t("admin.users.show.col_changes") %></th>
              <th><%= t("admin.users.show.col_admin") %></th>
            </tr>
          </thead>
          <tbody>
            <% @audit_events.each do |audit| %>
              <tr>
                <td><%= t("admin.audit_actions.#{audit.action}", default: audit.action.humanize) %></td>
                <td><%= audit.created_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td>
                  <% if audit.before_state.present? || audit.after_state.present? %>
                    <details>
                      <summary><%= t("admin.users.show.before_after") %></summary>
                      <pre class="text-xs"><%= JSON.pretty_generate(audit.before_state || {}) %></pre>
                      <pre class="text-xs"><%= JSON.pretty_generate(audit.after_state || {}) %></pre>
                    </details>
                  <% end %>
                </td>
                <td><%= t("admin.users.show.admin_id", id: audit.acting_admin_id) %></td>
              </tr>
            <% end %>
            <% if @audit_events.empty? %>
              <tr>
                <td colspan="4" class="text-center"><%= t("admin.users.show.no_audit_events") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
