<div id="lifecycle_section" class="mt-6 pt-4 border-t">
  <h3 class="font-semibold mb-3">Lifecycle Management</h3>

  <% if notice.present? %>
    <div class="alert alert-success mb-2"><span><%= notice %></span></div>
  <% elsif error.present? %>
    <div class="alert alert-error mb-2"><span><%= error %></span></div>
  <% end %>

  <% if managed_user.active? %>
    <%= button_to "Deactivate User", deactivate_admin_user_path(managed_user), method: :post, class: "btn btn-error btn-sm", form: { data: { turbo_confirm: "Are you sure you want to deactivate this user?" } } %>
  <% else %>
    <%= button_to "Reactivate User", reactivate_admin_user_path(managed_user), method: :post, class: "btn btn-success btn-sm" %>
  <% end %>
</div>
