<div id="usage_section">
  <h3 class="font-semibold">Usage Limits</h3>

  <% if notice.present? %>
    <div class="alert alert-success mt-2"><span><%= notice %></span></div>
  <% elsif error.present? %>
    <div class="alert alert-error mt-2"><span><%= error %></span></div>
  <% end %>

  <% if workspace.present? %>
    <div class="mb-2">
      <label class="text-sm">Scans</label>
      <div class="flex items-center gap-2">
        <progress class="progress progress-primary w-24" value="<%= workspace.usage_consumed_for(:scans) %>" max="<%= workspace.usage_limit_for(:scans, 0) %>"></progress>
        <span class="text-sm"><%= workspace.usage_consumed_for(:scans) %> / <%= workspace.usage_limit_for(:scans, 0) %></span>
      </div>
    </div>
    <div class="mb-2">
      <label class="text-sm">Storage (MB)</label>
      <div class="flex items-center gap-2">
        <progress class="progress progress-primary w-24" value="<%= workspace.usage_consumed_for(:storage_mb) %>" max="<%= workspace.usage_limit_for(:storage_mb, 0) %>"></progress>
        <span class="text-sm"><%= workspace.usage_consumed_for(:storage_mb) %> / <%= workspace.usage_limit_for(:storage_mb, 0) %></span>
      </div>
    </div>

    <%= form_with url: update_usage_admin_user_path(managed_user), method: :patch, class: "mt-4" do |f| %>
      <div class="form-control">
        <%= f.label :scans, "Scans Limit", class: "label" %>
        <%= f.number_field :scans, value: workspace.usage_limit_for(:scans, 0), min: 0, class: "input input-bordered" %>
      </div>
      <div class="form-control">
        <%= f.label :storage_mb, "Storage (MB) Limit", class: "label" %>
        <%= f.number_field :storage_mb, value: workspace.usage_limit_for(:storage_mb, 0), min: 0, class: "input input-bordered" %>
      </div>
      <%= f.submit "Update Limits", class: "btn btn-sm mt-2" %>
    <% end %>
  <% else %>
    <p class="text-sm text-base-content/70">No workspace assigned for this user.</p>
  <% end %>
</div>
