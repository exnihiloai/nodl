<% content_for :title, t("admin.users.new.title") %>

<section class="container mx-auto px-4 py-10">
  <div class="breadcrumbs text-sm mb-4">
    <ul>
      <li><%= link_to t("admin.breadcrumbs.dashboard"), dashboard_path, class: "link" %></li>
      <li><%= link_to t("admin.breadcrumbs.users"), admin_users_path, class: "link" %></li>
      <li><%= t("admin.users.new.create_user") %></li>
    </ul>
  </div>

  <div class="card bg-base-100 shadow-sm mt-6 max-w-2xl">
    <div class="card-body">
      <%= form_with url: admin_users_path, method: :post, class: "space-y-4" do |f| %>
        <div class="form-control">
          <%= f.label :email, class: "label" do %>
            <span class="label-text"><%= t("admin.users.new.email") %></span>
          <% end %>
          <%= f.email_field :email, required: true, class: "input input-bordered w-full", placeholder: t("admin.users.new.email_placeholder") %>
        </div>

        <div class="form-control">
          <%= f.label :role, class: "label" do %>
            <span class="label-text"><%= t("admin.users.new.role") %></span>
          <% end %>
          <%= f.select :role, options_for_select([[t("admin.roles.user"), "user"], [t("admin.roles.admin"), "admin"]]), {}, class: "select select-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :password, class: "label" do %>
            <span class="label-text"><%= t("admin.users.new.password") %></span>
            <span class="label-text-alt text-base-content/70"><%= t("admin.users.new.password_optional") %></span>
          <% end %>
          <%= render "shared/password_field", f:, field: :password, minlength: 8, class: "input input-bordered w-full", placeholder: t("admin.users.new.password_placeholder") %>
        </div>

        <div class="form-control mt-6">
          <%= f.submit t("admin.users.new.create_user"), class: "btn btn-primary" %>
        </div>
      <% end %>

      <%= turbo_frame_tag "create_result", class: "mt-4" %>
    </div>
  </div>
</section>
