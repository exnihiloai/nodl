<% content_for :title, t("admin.users.index.title") %>

<section class="container mx-auto px-4 py-10">
  <div class="breadcrumbs text-sm mb-4">
    <ul>
      <li><%= link_to t("admin.breadcrumbs.dashboard"), dashboard_path, class: "link" %></li>
      <li><%= t("admin.breadcrumbs.admin") %></li>
      <li><%= t("admin.breadcrumbs.users") %></li>
    </ul>
  </div>

  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold mb-1"><%= t("admin.users.index.heading") %></h1>
      <p class="text-base-content/70"><%= t("admin.users.index.subheading") %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to t("admin.users.index.create_user"), new_admin_user_path, class: "btn btn-primary btn-sm" %>
    </div>
  </div>

  <div class="mt-6 card bg-base-100 shadow-sm">
    <div class="card-body p-0">
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th><%= t("admin.users.index.col_user") %></th>
              <th><%= t("admin.users.index.col_role") %></th>
              <th><%= t("admin.users.index.col_created") %></th>
              <th><%= t("admin.users.index.col_last_login") %></th>
              <th><%= t("admin.users.index.col_workspace") %></th>
              <th><%= t("admin.users.index.col_plan") %></th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <% workspace = user.workspaces.order("memberships.created_at ASC").first %>
              <tr class="align-top">
                <td>
                  <div class="flex flex-col">
                    <span class="font-medium"><%= link_to user.email, admin_user_path(user), class: "link" %></span>
                    <span class="text-xs text-base-content/70"><%= t("admin.users.index.id", id: user.id) %></span>
                  </div>
                </td>
                <td>
                  <% if user.admin? %>
                    <span class="badge badge-warning badge-outline"><%= t("admin.roles.admin") %></span>
                  <% else %>
                    <span class="badge badge-outline"><%= t("admin.roles.user") %></span>
                  <% end %>
                  <% unless user.active? %>
                    <span class="badge badge-error badge-sm ml-1"><%= t("admin.common.inactive") %></span>
                  <% end %>
                </td>
                <td><%= user.created_at&.strftime("%Y-%m-%d %H:%M") || t("admin.common.none") %></td>
                <td><%= user.last_login_at&.strftime("%Y-%m-%d %H:%M") || t("admin.common.never") %></td>
                <td><%= workspace&.name || t("admin.common.none") %></td>
                <td><%= workspace&.current_entitlement&.display_name || t("admin.common.free") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
