<div id="password_section" class="mt-4">
  <label class="label">Password</label>

  <% if notice.present? %>
    <div class="alert alert-success mt-2"><span><%= notice %></span></div>
  <% elsif error.present? %>
    <div class="alert alert-error mt-2"><span><%= error %></span></div>
  <% end %>

  <% if generated_password.present? %>
    <div class="alert alert-warning mt-2 flex-col items-start">
      <span class="font-semibold">Generated Password</span>
      <code class="text-lg font-mono bg-base-200 p-2 rounded mt-2 block"><%= generated_password %></code>
      <span class="text-sm">Copy this now. It will not be shown again.</span>
    </div>
  <% end %>

  <%= button_to "Generate Temporary Password", generate_password_admin_user_path(managed_user), method: :post, class: "btn btn-sm btn-outline mt-2" %>

  <%= form_with url: update_password_admin_user_path(managed_user), method: :patch, class: "mt-2" do |f| %>
    <%= f.password_field :password, placeholder: "Enter new password", class: "input input-bordered w-full", minlength: 8, required: true %>
    <%= f.submit "Set Password", class: "btn btn-sm mt-2" %>
  <% end %>
</div>
