<div id="password_section" class="mt-4">
  <label class="label"><%= t("admin.users.password_section.label") %></label>

  <% if notice.present? %>
    <div class="alert alert-success mt-2"><span><%= notice %></span></div>
  <% elsif error.present? %>
    <div class="alert alert-error mt-2"><span><%= error %></span></div>
  <% end %>

  <% if generated_password.present? %>
    <div class="alert alert-warning mt-2 flex-col items-start">
      <span class="font-semibold"><%= t("admin.users.password_section.generated_label") %></span>
      <code class="text-lg font-mono bg-base-200 p-2 rounded mt-2 block"><%= generated_password %></code>
      <span class="text-sm"><%= t("admin.users.password_section.generated_hint") %></span>
    </div>
  <% end %>

  <%= button_to t("admin.users.password_section.generate"), generate_password_admin_user_path(managed_user), method: :post, class: "btn btn-sm btn-outline mt-2" %>

  <%= form_with url: update_password_admin_user_path(managed_user), method: :patch, class: "mt-2" do |f| %>
    <%= f.password_field :password, placeholder: t("admin.users.password_section.placeholder"), class: "input input-bordered w-full", minlength: 8, required: true %>
    <%= f.submit t("admin.users.password_section.set"), class: "btn btn-sm mt-2" %>
  <% end %>
</div>
