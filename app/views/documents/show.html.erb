<% content_for :title, "#{@document.title} - Nodl" %>

<section class="bg-base-200 py-10">
  <div class="container mx-auto px-4 max-w-5xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-3">
        <div>
          <h1 class="text-3xl font-bold"><%= @document.title %></h1>
          <p class="text-base-content/70"><%= @document.transformer_handle.humanize %> · <%= l(@document.generated_at, format: :short) %></p>
        </div>

        <div class="dropdown" data-testid="download-menu">
          <label tabindex="0" class="btn btn-sm gap-2">
            <%= icon "download", class: "h-4 w-4" %>
            Download
          </label>
          <ul tabindex="0" class="dropdown-content menu z-10 mt-1 w-44 rounded-box border border-base-300 bg-base-100 p-1 shadow">
            <li><%= link_to "PDF", download_document_path(@document, format: "pdf"), data: { testid: "download-pdf" } %></li>
            <li><%= link_to "Word (.docx)", download_document_path(@document, format: "docx"), data: { testid: "download-docx" } %></li>
            <li><%= link_to "Markdown", download_document_path(@document, format: "md"), data: { testid: "download-md" } %></li>
          </ul>
        </div>
      </div>

      <%= link_to "Show Recording", recording_session_path(@recording_session), class: "btn btn-outline" %>
    </div>

    <article
      class="prose dark:prose-invert relative max-w-none rounded-box border border-base-300 bg-base-100 p-6 shadow-sm"
      data-controller="clipboard"
    >
      <button
        type="button"
        class="not-prose btn btn-ghost btn-sm absolute right-4 top-4 gap-2"
        data-action="clipboard#copy"
        data-testid="copy-document"
        aria-label="Copy document"
      >
        <span data-clipboard-target="copyIcon"><%= icon "copy", class: "h-4 w-4" %></span>
        <span data-clipboard-target="checkIcon" class="hidden text-success"><%= icon "check", class: "h-4 w-4" %></span>
        <span data-clipboard-target="label">Copy</span>
      </button>

      <div data-clipboard-target="source">
        <%= render_markdown(@document.content) %>
      </div>
    </article>
  </div>
</section>
