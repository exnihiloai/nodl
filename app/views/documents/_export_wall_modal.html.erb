<%#
  Wall 3: export limit. Opened on the reach-forward (clicking any download format)
  once a trial workspace has used its one free export. Copy, view, and edit stay
  free forever. Dismissible via X, backdrop, or "Maybe later".
%>
<dialog class="modal" data-export-wall-target="dialog" data-testid="export-wall-modal">
  <div class="modal-box max-w-md text-left">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-3 top-3" aria-label="<%= t("dashboard.wall.exports.close") %>">✕</button>
    </form>

    <h3 class="pr-8 text-xl font-bold leading-snug"><%= t("dashboard.wall.exports.heading") %></h3>
    <p class="mt-2 text-sm text-base-content/60"><%= t("dashboard.wall.exports.body") %></p>

    <div class="mt-5 overflow-hidden rounded-xl border border-base-300 bg-base-200 px-4 py-4">
      <p class="text-xs font-medium uppercase tracking-wide text-base-content/40"><%= t("dashboard.wall.exports.proof_heading") %></p>
      <ul class="mt-2 space-y-1.5" data-testid="export-wall-formats">
        <% [
             t("documents.show.pdf"),
             t("documents.show.docx"),
             t("documents.show.markdown")
           ].each do |label| %>
          <li class="flex items-center gap-2 text-sm font-medium">
            <%= icon("check", class: "size-4 shrink-0 text-success") %>
            <%= label %>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="mt-5 flex flex-wrap justify-center gap-1.5">
      <% [
           ["rotate-ccw", t("dashboard.wall.exports.cancel_anytime")],
           ["shield-check", t("dashboard.wall.exports.gdpr")],
           ["lock",         t("dashboard.wall.exports.encryption")],
           ["badge-check",  t("dashboard.wall.exports.money_back")]
         ].each do |lucide_icon, label| %>
        <span class="inline-flex items-center gap-1 rounded-full border border-base-300 bg-base-100 px-2.5 py-0.5 text-xs font-medium text-base-content/55">
          <%= icon(lucide_icon, class: "size-3 shrink-0") %>
          <%= label %>
        </span>
      <% end %>
    </div>

    <div class="mt-3 flex flex-col gap-2">
      <%= button_to t("dashboard.wall.exports.upgrade"), payments_checkout_path(plan: "starter"),
                    method: :post,
                    class: "btn btn-primary w-full",
                    form: { class: "w-full", data: { turbo: false } },
                    data: { testid: "export-wall-upgrade-button" } %>
      <%= link_to t("dashboard.wall.exports.see_plans"), payments_path,
                  class: "btn btn-ghost w-full",
                  data: { testid: "export-wall-see-plans-button" } %>
    </div>

    <div class="mt-3 text-center">
      <form method="dialog" class="contents">
        <button class="link link-hover text-xs text-base-content/40" data-testid="export-wall-dismiss"><%= t("dashboard.wall.exports.dismiss") %></button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button aria-label="<%= t("dashboard.wall.exports.close") %>">close</button>
  </form>
</dialog>
