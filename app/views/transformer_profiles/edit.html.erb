<% content_for :title, t("transformer_profiles.edit.title") %>

<section class="bg-base-200 py-10">
  <div class="container mx-auto max-w-2xl px-4">
    <div class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm">
      <div class="mb-6 flex items-start justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold"><%= t("transformer_profiles.edit.heading") %></h1>
        </div>
        <%= link_to t("transformer_profiles.edit.view"), transformer_profile_path(@transformer_profile), class: "btn btn-sm btn-ghost" %>
      </div>

      <%= render "form", transformer_profile: @transformer_profile %>
    </div>
  </div>
</section>
