<% content_for :title, "#{@transformer_profile.name} - Nodl" %>

<section class="bg-base-200 py-10">
  <div class="container mx-auto max-w-2xl px-4 space-y-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold" data-testid="format-name"><%= @transformer_profile.name %></h1>
        <p class="mt-1 text-sm text-base-content/60">
          <%= @transformer_profile.default? ? "Your workspace's default format." : "A custom format for your workspace." %>
        </p>
      </div>
      <div class="flex shrink-0 gap-2">
        <%= link_to "Edit", edit_transformer_profile_path(@transformer_profile), class: "btn btn-sm", data: { testid: "edit-format-button" } %>
        <% unless @transformer_profile.default? %>
          <%= button_to "Delete",
                        transformer_profile_path(@transformer_profile),
                        method: :delete,
                        class: "btn btn-sm btn-ghost text-error",
                        data: { testid: "delete-format-button", turbo_confirm: "Delete this format? This cannot be undone." } %>
        <% end %>
      </div>
    </div>

    <div class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm space-y-2">
      <h2 class="text-sm font-semibold">Guidelines</h2>
      <p class="text-xs text-base-content/50">How NODL writes documents in this format.</p>
      <% if @transformer_profile.instructions.present? %>
        <div class="mt-2 whitespace-pre-wrap rounded-box bg-base-200 p-4 text-sm" data-testid="format-instructions"><%= @transformer_profile.instructions %></div>
      <% else %>
        <p class="mt-2 text-sm text-base-content/60" data-testid="format-instructions">No guidelines added yet.</p>
      <% end %>
    </div>

    <div class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm space-y-2">
      <h2 class="text-sm font-semibold">Examples</h2>
      <p class="text-xs text-base-content/50">Documents NODL uses to match your preferred structure and style.</p>
      <% if @example_previews.any? %>
        <div class="mt-2 space-y-4" data-testid="format-examples">
          <% @example_previews.each do |file, preview| %>
            <div class="overflow-hidden rounded-box border border-base-300">
              <div class="border-b border-base-300 bg-base-200 px-3 py-2 text-sm font-medium"><%= file.filename %></div>
              <% if preview.present? %>
                <pre class="max-h-72 overflow-auto whitespace-pre-wrap p-3 text-xs text-base-content/70"><%= preview.strip %></pre>
              <% else %>
                <p class="p-3 text-xs italic text-base-content/50">Preview not available for this file.</p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-base-content/60">No example documents added.</p>
      <% end %>
    </div>

    <%= link_to "Back to dashboard", dashboard_path, class: "btn btn-ghost btn-sm" %>
  </div>
</section>
