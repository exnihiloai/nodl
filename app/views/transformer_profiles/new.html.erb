<% content_for :title, "Create a format - Nodl" %>

<section class="bg-base-200 py-10">
  <div class="container mx-auto max-w-2xl px-4">
    <div class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm">
      <div class="mb-6">
        <h1 class="text-2xl font-bold">Create your own format</h1>
        <p class="mt-1 text-sm text-base-content/60">Create a format for documents you make often, and tell NODL exactly how you want them.</p>
      </div>

      <%= render "form", transformer_profile: @transformer_profile %>
    </div>
  </div>
</section>
