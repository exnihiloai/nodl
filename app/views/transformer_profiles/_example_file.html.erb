<li id="<%= dom_id(file) %>" class="flex items-center justify-between gap-3 border-t border-base-300 p-3 first:border-t-0" data-testid="example-file-item">
  <span class="truncate text-sm"><%= file.filename %></span>
<%# A link (not button_to) so we don't nest a <form> inside the edit form,
      which would close it early and orphan the Save button. %>
  <%= link_to t("transformer_profiles.example_file.remove"),
              example_file_transformer_profile_path(transformer_profile, file),
              class: "btn btn-ghost btn-xs text-error",
              data: {
                testid: "remove-example-file-button",
                turbo_method: :delete,
                turbo_confirm: t("transformer_profiles.example_file.remove_confirm"),
                turbo_confirm_button: t("transformer_profiles.example_file.remove")
              } %>
</li>
