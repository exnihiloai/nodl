<% content_for :title, "About - Nodl" %>
<% content_for :head do %>
  <meta name="description" content="About this Rails SaaS starter." />
<% end %>

<section class="hero min-h-[60vh] bg-base-200">
  <div class="hero-content text-center flex-col gap-6">
    <h1 class="text-4xl sm:text-5xl font-bold">About This Platform</h1>
    <p class="max-w-2xl text-base-content/70">
      A modern SaaS starter built with Rails, Turbo, Tailwind, and DaisyUI.
    </p>
  </div>
</section>

<section class="py-16 bg-base-100">
  <div class="container mx-auto px-4 space-y-10">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card bg-base-200">
        <div class="card-body items-center text-center gap-3">
          <h3 class="card-title">Backend</h3>
          <ul class="text-sm text-base-content/70 space-y-1">
            <li>Rails 8</li>
            <li>PostgreSQL</li>
            <li>Multi-tenant workspaces</li>
            <li>Built-in secure auth</li>
          </ul>
        </div>
      </div>
      <div class="card bg-base-200">
        <div class="card-body items-center text-center gap-3">
          <h3 class="card-title">Frontend</h3>
          <ul class="text-sm text-base-content/70 space-y-1">
            <li>ERB server rendering</li>
            <li>Turbo Frames/Streams</li>
            <li>Tailwind utilities</li>
            <li>DaisyUI components</li>
          </ul>
        </div>
      </div>
      <div class="card bg-base-200">
        <div class="card-body items-center text-center gap-3">
          <h3 class="card-title">Ops</h3>
          <ul class="text-sm text-base-content/70 space-y-1">
            <li>Dockerized local setup</li>
            <li>Health/readiness endpoints</li>
            <li>Stripe webhook placeholder</li>
            <li>Rails production image</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="card bg-base-200">
      <div class="card-body items-center text-center gap-4">
        <h2 class="card-title">Version information</h2>
        <p class="text-base-content/70">Current app version</p>
        <div class="badge badge-primary badge-lg"><%= Rails.application.config.x.app_version || "dev" %></div>
        <div class="card-actions">
          <%= link_to "Back to Home", root_path, class: "btn btn-primary" %>
          <%= link_to "Try the demo", try_now_path, class: "btn btn-outline" %>
        </div>
      </div>
    </div>
  </div>
</section>
