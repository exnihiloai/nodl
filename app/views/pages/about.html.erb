<% content_for :title, t("pages.about.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("pages.about.meta_description") %>" />
<% end %>

<section class="hero min-h-[60vh] bg-base-200">
  <div class="hero-content text-center flex-col gap-6">
    <h1 class="text-4xl sm:text-5xl font-bold"><%= t("pages.about.heading") %></h1>
    <p class="max-w-2xl text-base-content/70">
      <%= t("pages.about.intro") %>
    </p>
  </div>
</section>

<section class="py-16 bg-base-100">
  <div class="container mx-auto px-4 space-y-10">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card bg-base-200">
        <div class="card-body items-center text-center gap-3">
          <h3 class="card-title"><%= t("pages.about.backend.title") %></h3>
          <ul class="text-sm text-base-content/70 space-y-1">
            <li><%= t("pages.about.backend.item_1") %></li>
            <li><%= t("pages.about.backend.item_2") %></li>
            <li><%= t("pages.about.backend.item_3") %></li>
            <li><%= t("pages.about.backend.item_4") %></li>
          </ul>
        </div>
      </div>
      <div class="card bg-base-200">
        <div class="card-body items-center text-center gap-3">
          <h3 class="card-title"><%= t("pages.about.frontend.title") %></h3>
          <ul class="text-sm text-base-content/70 space-y-1">
            <li><%= t("pages.about.frontend.item_1") %></li>
            <li><%= t("pages.about.frontend.item_2") %></li>
            <li><%= t("pages.about.frontend.item_3") %></li>
            <li><%= t("pages.about.frontend.item_4") %></li>
          </ul>
        </div>
      </div>
      <div class="card bg-base-200">
        <div class="card-body items-center text-center gap-3">
          <h3 class="card-title"><%= t("pages.about.ops.title") %></h3>
          <ul class="text-sm text-base-content/70 space-y-1">
            <li><%= t("pages.about.ops.item_1") %></li>
            <li><%= t("pages.about.ops.item_2") %></li>
            <li><%= t("pages.about.ops.item_3") %></li>
            <li><%= t("pages.about.ops.item_4") %></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="card bg-base-200">
      <div class="card-body items-center text-center gap-4">
        <h2 class="card-title"><%= t("pages.about.version.title") %></h2>
        <p class="text-base-content/70"><%= t("pages.about.version.current") %></p>
        <div class="badge badge-primary badge-lg"><%= Rails.application.config.x.app_version %></div>
        <div class="card-actions">
          <%= link_to t("pages.about.version.back_home"), root_path, class: "btn btn-primary" %>
          <%= link_to t("pages.about.version.try_demo"), try_now_path, class: "btn btn-outline" %>
        </div>
      </div>
    </div>
  </div>
</section>
