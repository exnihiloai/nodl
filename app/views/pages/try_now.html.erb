<% content_for :title, "Try Nodl - Demo" %>
<% content_for :head do %>
  <meta name="description" content="Explore the demo experience." />
<% end %>

<section class="bg-gradient-to-br from-base-200 via-base-100 to-base-200 py-20">
  <div class="container mx-auto px-4 max-w-3xl flex flex-col items-center gap-8 text-center">
    <div class="space-y-3">
      <span class="badge badge-primary badge-lg">Interactive demo</span>
      <h1 class="text-4xl font-semibold">Experience the platform</h1>
      <p class="text-base-content/70 text-lg">Explore core features and see how this Rails stack accelerates your workflow.</p>
    </div>

    <div class="card bg-base-100 shadow-lg w-full">
      <div class="card-body space-y-4 text-left">
        <h2 class="card-title">Demo features</h2>
        <div class="grid md:grid-cols-2 gap-3 text-sm text-base-content/70">
          <span class="badge badge-outline justify-start">Multi-tenant dashboard</span>
          <span class="badge badge-outline justify-start">Turbo HTML updates</span>
          <span class="badge badge-outline justify-start">Admin user lifecycle actions</span>
          <span class="badge badge-outline justify-start">Stripe checkout placeholder</span>
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <%= link_to "Start your free trial", register_path, class: "btn btn-primary btn-lg" %>
      <%= link_to "Learn more", about_path, class: "btn btn-outline btn-lg" %>
    </div>

    <%= link_to "← Back to homepage", root_path, class: "link link-hover" %>
  </div>
</section>
