<% content_for :title, t("pages.try_now.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("pages.try_now.meta_description") %>" />
<% end %>

<section class="bg-gradient-to-br from-base-200 via-base-100 to-base-200 py-20">
  <div class="container mx-auto px-4 max-w-3xl flex flex-col items-center gap-8 text-center">
    <div class="space-y-3">
      <span class="badge badge-primary badge-lg"><%= t("pages.try_now.badge") %></span>
      <h1 class="text-4xl font-semibold"><%= t("pages.try_now.heading") %></h1>
      <p class="text-base-content/70 text-lg"><%= t("pages.try_now.subheading") %></p>
    </div>

    <div class="card bg-base-100 shadow-lg w-full">
      <div class="card-body space-y-4 text-left">
        <h2 class="card-title"><%= t("pages.try_now.features_title") %></h2>
        <div class="grid md:grid-cols-2 gap-3 text-sm text-base-content/70">
          <span class="badge badge-outline justify-start"><%= t("pages.try_now.feature_1") %></span>
          <span class="badge badge-outline justify-start"><%= t("pages.try_now.feature_2") %></span>
          <span class="badge badge-outline justify-start"><%= t("pages.try_now.feature_3") %></span>
          <span class="badge badge-outline justify-start"><%= t("pages.try_now.feature_4") %></span>
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <%= link_to t("pages.try_now.start_trial"), register_path, class: "btn btn-primary btn-lg" %>
      <%= link_to t("pages.try_now.learn_more"), about_path, class: "btn btn-outline btn-lg" %>
    </div>

    <%= link_to t("pages.try_now.back_home"), root_path, class: "link link-hover" %>
  </div>
</section>
