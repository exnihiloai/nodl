<% content_for :title, t("pages.public_home.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("pages.public_home.meta_description") %>" />
<% end %>

<section class="bg-base-100 py-20 sm:py-28">
  <div class="container mx-auto px-4 max-w-3xl text-center space-y-6">
    <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl border border-base-300 bg-base-200">
      <%= icon("nodl-mark", class: "w-9 h-5") %>
    </div>
    <div class="space-y-3">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight"><%= t("pages.public_home.heading") %></h1>
      <p class="text-lg text-base-content/70"><%= t("pages.public_home.body") %></p>
    </div>
    <div class="flex flex-col sm:flex-row justify-center gap-3">
      <%= link_to t("nav.register"), register_path, class: "btn btn-primary btn-lg" %>
      <%= link_to t("nav.login"), login_path, class: "btn btn-outline btn-lg" %>
    </div>
  </div>
</section>
