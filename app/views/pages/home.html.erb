<% content_for :title, t("pages.home.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("pages.home.meta_description") %>" />
<% end %>

<section class="bg-gradient-to-br from-base-200 via-base-100 to-base-300 py-20">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="hero rounded-3xl bg-base-200 shadow-2xl">
      <div class="hero-content flex-col lg:flex-row gap-12 p-12">
        <div class="max-w-xl space-y-6">
          <span class="badge badge-info badge-lg gap-2 uppercase tracking-wide"><%= t("pages.home.hero.badge") %></span>
          <h1 class="text-4xl sm:text-5xl font-bold leading-tight"><%= t("pages.home.hero.heading") %></h1>
          <p class="text-lg text-base-content/70">
            <%= t("pages.home.hero.subheading") %>
          </p>
          <div class="flex flex-wrap gap-3">
            <%= link_to t("pages.home.hero.get_started"), register_path, class: "btn btn-primary btn-lg" %>
            <%= link_to t("pages.home.hero.live_demo"), try_now_path, class: "btn btn-secondary btn-lg" %>
            <%= link_to t("pages.home.hero.check_status"), readyz_path(format: :html), class: "btn btn-outline btn-lg", data: { turbo_frame: "status_check" } %>
          </div>
          <%= turbo_frame_tag "status_check", class: "text-sm text-base-content/60" do %>
            <%= t("pages.home.hero.status_unchecked") %>
          <% end %>
        </div>
        <div class="grid gap-4 w-full lg:w-5/12">
          <article class="card bg-base-100/90 border border-base-200/60 shadow-xl">
            <div class="card-body space-y-2">
              <div class="flex items-center gap-2">
                <%= icon("activity", class: "size-5 text-primary", label: t("pages.home.cards.observability.label")) %>
                <h2 class="card-title text-lg"><%= t("pages.home.cards.observability.title") %></h2>
              </div>
              <p class="text-base-content/70 text-sm"><%= t("pages.home.cards.observability.body") %></p>
            </div>
          </article>
          <article class="card bg-base-100/90 border border-base-200/60 shadow-xl">
            <div class="card-body space-y-2">
              <div class="flex items-center gap-2">
                <%= icon("shield-check", class: "size-5 text-success", label: t("pages.home.cards.security.label")) %>
                <h2 class="card-title text-lg"><%= t("pages.home.cards.security.title") %></h2>
              </div>
              <p class="text-base-content/70 text-sm"><%= t("pages.home.cards.security.body") %></p>
            </div>
          </article>
          <article class="card bg-base-100/90 border border-base-200/60 shadow-xl">
            <div class="card-body space-y-2">
              <div class="flex items-center gap-2">
                <%= icon("rocket", class: "size-5 text-accent", label: t("pages.home.cards.velocity.label")) %>
                <h2 class="card-title text-lg"><%= t("pages.home.cards.velocity.title") %></h2>
              </div>
              <p class="text-base-content/70 text-sm"><%= t("pages.home.cards.velocity.body") %></p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="services" class="py-20 bg-base-100">
  <div class="container mx-auto px-4 max-w-6xl space-y-10">
    <div class="text-center space-y-3 max-w-2xl mx-auto">
      <span class="badge badge-outline badge-lg"><%= t("pages.home.services.badge") %></span>
      <h2 class="text-3xl font-semibold"><%= t("pages.home.services.heading") %></h2>
      <p class="text-base-content/70"><%= t("pages.home.services.subheading") %></p>
    </div>
    <div role="tablist" class="tabs tabs-boxed flex-nowrap overflow-x-auto">
      <input type="radio" name="use-case" role="tab" class="tab text-sm sm:text-base" aria-label="<%= t("pages.home.services.seed.tab") %>" checked />
      <div role="tabpanel" class="tab-content bg-base-200 border border-base-300 rounded-box p-6 space-y-4">
        <h3 class="text-xl font-semibold"><%= t("pages.home.services.seed.title") %></h3>
        <ul class="list-disc list-inside text-base-content/70 space-y-1">
          <li><%= t("pages.home.services.seed.item_1") %></li>
          <li><%= t("pages.home.services.seed.item_2") %></li>
          <li><%= t("pages.home.services.seed.item_3") %></li>
        </ul>
      </div>

      <input type="radio" name="use-case" role="tab" class="tab text-sm sm:text-base" aria-label="<%= t("pages.home.services.internal.tab") %>" />
      <div role="tabpanel" class="tab-content bg-base-200 border border-base-300 rounded-box p-6 space-y-4">
        <h3 class="text-xl font-semibold"><%= t("pages.home.services.internal.title") %></h3>
        <ul class="list-disc list-inside text-base-content/70 space-y-1">
          <li><%= t("pages.home.services.internal.item_1") %></li>
          <li><%= t("pages.home.services.internal.item_2") %></li>
          <li><%= t("pages.home.services.internal.item_3") %></li>
        </ul>
      </div>

      <input type="radio" name="use-case" role="tab" class="tab text-sm sm:text-base" aria-label="<%= t("pages.home.services.agencies.tab") %>" />
      <div role="tabpanel" class="tab-content bg-base-200 border border-base-300 rounded-box p-6 space-y-4">
        <h3 class="text-xl font-semibold"><%= t("pages.home.services.agencies.title") %></h3>
        <ul class="list-disc list-inside text-base-content/70 space-y-1">
          <li><%= t("pages.home.services.agencies.item_1") %></li>
          <li><%= t("pages.home.services.agencies.item_2") %></li>
          <li><%= t("pages.home.services.agencies.item_3") %></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section id="faq" class="py-20 bg-base-100">
  <div class="container mx-auto px-4 max-w-4xl space-y-8">
    <div class="text-center space-y-3">
      <span class="badge badge-outline badge-lg"><%= t("pages.home.faq.badge") %></span>
      <h2 class="text-3xl font-semibold"><%= t("pages.home.faq.heading") %></h2>
      <p class="text-base-content/70"><%= t("pages.home.faq.subheading") %></p>
    </div>
    <div class="space-y-4">
      <div class="collapse collapse-arrow bg-base-200 shadow">
        <input type="radio" name="faq" checked />
        <div class="collapse-title text-lg font-semibold"><%= t("pages.home.faq.q1") %></div>
        <div class="collapse-content text-base-content/70">
          <p><%= t("pages.home.faq.a1") %></p>
        </div>
      </div>
      <div class="collapse collapse-arrow bg-base-200 shadow">
        <input type="radio" name="faq" />
        <div class="collapse-title text-lg font-semibold"><%= t("pages.home.faq.q2") %></div>
        <div class="collapse-content text-base-content/70">
          <p><%= t("pages.home.faq.a2") %></p>
        </div>
      </div>
      <div class="collapse collapse-arrow bg-base-200 shadow">
        <input type="radio" name="faq" />
        <div class="collapse-title text-lg font-semibold"><%= t("pages.home.faq.q3") %></div>
        <div class="collapse-content text-base-content/70">
          <p><%= t("pages.home.faq.a3") %></p>
        </div>
      </div>
    </div>
  </div>
</section>
