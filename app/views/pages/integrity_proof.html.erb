<% content_for :title, t("pages.integrity_proof.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("pages.integrity_proof.meta_description") %>">
<% end %>

<% proof_steps = [
  t("pages.integrity_proof.sections.how.step_1"),
  t("pages.integrity_proof.sections.how.step_2"),
  t("pages.integrity_proof.sections.how.step_3")
] %>

<% technical_step_keys = %w[prepare hash proof timestamp] %>
<% technical_field_keys = t("pages.integrity_proof.sections.technical.fields.items").keys.map(&:to_s) %>

<section class="bg-base-200 py-10 sm:py-12">
  <div class="container mx-auto max-w-3xl space-y-6 px-4">
    <% back_fallback = user_signed_in? ? dashboard_path : root_path %>
    <%= button_tag t("pages.integrity_proof.back_link"),
                   type: "button",
                   class: "link link-hover inline-flex cursor-pointer items-center gap-1 border-0 bg-transparent p-0 text-sm",
                   data: { testid: "integrity-proof-back" },
                   onclick: "if (history.length > 1) { history.back(); } else { window.location.assign(#{back_fallback.to_json}); }" %>

    <article class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm sm:p-8" data-testid="integrity-proof-help">
      <header class="flex items-start gap-4">
        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-primary/20 bg-primary/10 text-primary">
          <%= icon("shield-check", class: "size-7", label: t("pages.integrity_proof.heading")) %>
        </span>
        <div class="min-w-0">
          <h1 class="text-3xl font-bold tracking-tight"><%= t("pages.integrity_proof.heading") %></h1>
          <p class="mt-2 text-base leading-relaxed text-base-content/70"><%= t("pages.integrity_proof.intro") %></p>
        </div>
      </header>

      <aside class="mt-8 rounded-box border border-success/25 bg-success/5 p-5 sm:p-6" data-testid="integrity-proof-summary">
        <p class="text-xs font-semibold uppercase tracking-wide text-success"><%= t("pages.integrity_proof.proof_summary.heading") %></p>
        <ul class="mt-4 space-y-4">
          <li class="flex gap-4" data-testid="integrity-proof-claim-unchanged">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-success/15 text-success">
              <%= icon("lock", class: "size-5", label: t("pages.integrity_proof.proof_summary.unchanged.title")) %>
            </span>
            <div class="min-w-0 pt-0.5">
              <p class="font-semibold leading-snug"><%= t("pages.integrity_proof.proof_summary.unchanged.title") %></p>
              <p class="mt-1 text-sm leading-relaxed text-base-content/70"><%= t("pages.integrity_proof.proof_summary.unchanged.body") %></p>
            </div>
          </li>
          <li class="flex gap-4" data-testid="integrity-proof-claim-exists-since">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-success/15 text-success">
              <%= icon("clock", class: "size-5", label: t("pages.integrity_proof.proof_summary.exists_since.title")) %>
            </span>
            <div class="min-w-0 pt-0.5">
              <p class="font-semibold leading-snug"><%= t("pages.integrity_proof.proof_summary.exists_since.title") %></p>
              <p class="mt-1 text-sm leading-relaxed text-base-content/70"><%= t("pages.integrity_proof.proof_summary.exists_since.body") %></p>
            </div>
          </li>
        </ul>
      </aside>

      <div class="prose prose-sm mt-10 max-w-none dark:prose-invert">
        <h2><%= t("pages.integrity_proof.sections.what.heading") %></h2>
        <p><%= t("pages.integrity_proof.sections.what.body") %></p>

        <h2><%= t("pages.integrity_proof.sections.how.heading") %></h2>
      </div>

      <ol class="mt-4 space-y-4 not-prose">
        <% proof_steps.each_with_index do |step, index| %>
          <li class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary" aria-hidden="true">
              <%= index + 1 %>
            </span>
            <p class="min-w-0 pt-1 text-sm leading-relaxed text-base-content/80"><%= step %></p>
          </li>
        <% end %>
      </ol>

      <div class="prose prose-sm mt-10 max-w-none dark:prose-invert">
        <h2><%= t("pages.integrity_proof.sections.archive.heading") %></h2>
        <p><%= t("pages.integrity_proof.sections.archive.body") %></p>

        <h2><%= t("pages.integrity_proof.sections.verify.heading") %></h2>
        <p><%= t("pages.integrity_proof.sections.verify.body") %></p>
      </div>

      <section class="mt-8 rounded-box border border-base-300 bg-base-200/40 p-5 sm:p-6" data-testid="integrity-proof-technical">
        <div class="flex items-start gap-3">
          <%= icon("list-checks", class: "mt-0.5 size-5 shrink-0 text-primary", label: t("pages.integrity_proof.sections.technical.heading")) %>
          <div class="min-w-0">
            <h2 class="text-lg font-semibold"><%= t("pages.integrity_proof.sections.technical.heading") %></h2>
            <p class="mt-2 text-sm leading-relaxed text-base-content/70"><%= t("pages.integrity_proof.sections.technical.intro") %></p>
          </div>
        </div>

        <div class="alert mt-5 border border-info/30 bg-info/10 text-sm shadow-none" role="note" data-testid="integrity-proof-technical-audience">
          <%= icon("graduation-cap", class: "size-5 shrink-0 text-info", label: t("pages.integrity_proof.sections.technical.audience_callout.heading")) %>
          <div>
            <p class="font-medium text-info"><%= t("pages.integrity_proof.sections.technical.audience_callout.heading") %></p>
            <p class="mt-1 text-base-content/80"><%= t("pages.integrity_proof.sections.technical.audience_callout.body") %></p>
          </div>
        </div>

        <ol class="mt-6 space-y-5 not-prose">
          <% technical_step_keys.each_with_index do |step_key, index| %>
            <% step = t("pages.integrity_proof.sections.technical.steps.#{step_key}") %>
            <li class="flex gap-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary" aria-hidden="true">
                <%= index + 1 %>
              </span>
              <div class="min-w-0 pt-0.5">
                <p class="font-semibold leading-snug"><%= step[:title] %></p>
                <p class="mt-1 text-sm leading-relaxed text-base-content/70"><%= step[:body] %></p>
              </div>
            </li>
          <% end %>
        </ol>

        <div class="mt-8">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-base-content/60"><%= t("pages.integrity_proof.sections.technical.fields.heading") %></h3>
          <dl class="mt-3 space-y-3 not-prose">
            <% technical_field_keys.each do |field_key| %>
              <div class="rounded-box border border-base-300/80 bg-base-100/70 px-4 py-3">
                <dt class="font-mono text-xs font-semibold text-primary"><%= field_key %></dt>
                <dd class="mt-1 text-sm leading-relaxed text-base-content/70"><%= t("pages.integrity_proof.sections.technical.fields.items.#{field_key}") %></dd>
              </div>
            <% end %>
          </dl>
        </div>

        <div class="mt-8">
          <h3 class="text-sm font-semibold"><%= t("pages.integrity_proof.sections.technical.commands.heading") %></h3>
          <p class="mt-2 text-sm leading-relaxed text-base-content/70"><%= t("pages.integrity_proof.sections.technical.commands.note") %></p>
          <pre class="mt-3 overflow-x-auto rounded-box border border-base-300 bg-base-300/30 p-4 font-mono text-xs leading-relaxed text-base-content/90"><code><%= t("pages.integrity_proof.sections.technical.commands.example").strip %></code></pre>
        </div>
      </section>

      <div class="alert mt-8 border border-base-300/80 bg-base-200/50 text-sm" role="note">
        <%= icon("shield-check", class: "size-5 shrink-0 text-base-content/50", label: t("pages.integrity_proof.disclaimer.heading")) %>
        <div>
          <p class="font-medium"><%= t("pages.integrity_proof.disclaimer.heading") %></p>
          <p class="mt-1 text-base-content/70"><%= t("pages.integrity_proof.disclaimer.body") %></p>
        </div>
      </div>

      <div class="mt-8">
        <%= link_to t("pages.integrity_proof.back_to_dashboard"), user_signed_in? ? dashboard_path : root_path, class: "btn btn-primary" %>
      </div>
    </article>
  </div>
</section>
