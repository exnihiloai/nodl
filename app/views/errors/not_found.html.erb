<% content_for :title, t("errors.not_found.title") %>
<% content_for :head do %>
  <meta name="robots" content="noindex, nofollow" />
<% end %>

<section class="min-h-[70vh] bg-gradient-to-br from-primary/10 via-base-100 to-base-200 py-16 sm:py-24">
  <div class="container mx-auto px-4 max-w-3xl">
    <div class="text-center space-y-8">
      <div class="flex items-center justify-center gap-2 sm:gap-4" aria-hidden="true">
        <span class="text-[5rem] sm:text-[7rem] font-black leading-none tracking-tighter text-base-content/15">4</span>
        <div class="flex size-20 sm:size-28 shrink-0 items-center justify-center rounded-full border border-base-300 bg-base-100 shadow-xl ring-4 ring-primary/10">
          <%= icon("mic-off", class: "size-10 sm:size-14 text-primary", label: t("errors.not_found.icon_label")) %>
        </div>
        <span class="text-[5rem] sm:text-[7rem] font-black leading-none tracking-tighter text-base-content/15">4</span>
      </div>

      <div class="space-y-4">
        <span class="badge badge-outline badge-lg"><%= t("errors.not_found.badge") %></span>
        <h1 class="text-3xl sm:text-4xl font-bold leading-tight max-w-lg mx-auto"><%= t("errors.not_found.heading") %></h1>
        <p class="text-lg text-base-content/70 max-w-xl mx-auto"><%= t("errors.not_found.subheading") %></p>
      </div>

      <div class="mx-auto max-w-md rounded-2xl border border-base-300 bg-base-100/90 p-5 shadow-lg text-left space-y-3">
        <div class="flex items-center justify-between gap-3 text-xs uppercase tracking-wide text-base-content/50">
          <span class="truncate"><%= t("errors.not_found.transcript_label") %></span>
          <span class="badge badge-ghost badge-sm shrink-0"><%= t("errors.not_found.transcript_status") %></span>
        </div>
        <p class="font-mono text-sm text-base-content/70 italic break-words"><%= t("errors.not_found.transcript_body") %></p>
        <p class="text-sm text-base-content/60"><%= t("errors.not_found.hint") %></p>
      </div>

      <div class="flex flex-wrap justify-center gap-3">
        <%= link_to t("errors.not_found.cta_home"), root_path, class: "btn btn-primary btn-lg" %>
        <% if user_signed_in? %>
          <%= link_to t("errors.not_found.cta_dashboard"), dashboard_path, class: "btn btn-outline btn-lg" %>
        <% else %>
          <%= link_to t("errors.not_found.cta_try"), try_now_path, class: "btn btn-outline btn-lg" %>
        <% end %>
      </div>
    </div>
  </div>
</section>
