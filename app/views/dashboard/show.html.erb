<% content_for :title, "Dashboard - Nodl" %>
<% content_for :head do %>
  <meta name="description" content="Speak a thought and get a clean, structured document back." />
<% end %>

<section class="bg-base-200 py-10">
  <% if @workspace %>
    <%= turbo_stream_from @workspace, :dashboard %>
  <% end %>

  <div class="container mx-auto max-w-5xl px-4 space-y-10">
    <% unless @workspace %>
      <div class="rounded-box border border-base-300 bg-base-100 p-8 text-center">
        <h1 class="text-2xl font-bold">No workspace assigned</h1>
        <p class="mt-2 text-base-content/70">Ask an administrator to add you to a workspace to start recording.</p>
      </div>
    <% else %>
      <% first_run = @recording_sessions.none? %>

      <div class="rounded-box border border-base-300 bg-base-100 px-6 py-10 text-center shadow-sm" data-testid="record-hero">
        <% if first_run %>
          <h1 class="text-3xl font-bold">Speak. We'll structure it.</h1>
          <p class="mx-auto mt-2 max-w-md text-base-content/70">Capture a thought out loud and get a clean document back.</p>
        <% else %>
          <h1 class="text-xl font-semibold">Capture a thought</h1>
        <% end %>

        <%= form_with model: @recording_session,
                      url: recording_sessions_path,
                      local: true,
                      multipart: true,
                      class: "mt-6 flex flex-col items-center gap-4",
                      data: { controller: "audio-recorder" } do |form| %>
          <%= form.hidden_field :source_kind, value: "upload", data: { "audio-recorder-target": "sourceKind" } %>

          <div class="flex flex-wrap items-center justify-center gap-3">
            <%= form.button type: "button",
                            class: "btn btn-bouncy btn-primary btn-lg gap-2",
                            data: { "audio-recorder-target": "recordButton", action: "audio-recorder#start" } do %>
              <span class="text-lg" aria-hidden="true">●</span> Record
            <% end %>
            <button type="button" class="btn btn-outline hidden" data-audio-recorder-target="stopButton" data-action="audio-recorder#stop" disabled>Stop</button>
            <span class="font-mono text-sm text-base-content/60 hidden" data-audio-recorder-target="timer">00:00</span>
          </div>

          <label class="cursor-pointer text-sm text-base-content/60 hover:text-base-content hover:underline">
            or upload audio
            <%= form.file_field :original_audio,
                                accept: "audio/*,video/webm,video/mp4",
                                class: "hidden",
                                data: {
                                  "audio-recorder-target": "uploadInput",
                                  action: "change->audio-recorder#useUpload"
                                } %>
          </label>

          <div class="flex flex-wrap items-center justify-center gap-2 text-sm">
            <span class="text-base-content/60">Output:</span>
            <%= form.select :transformer_handle,
                            @transformer_profiles.map { |profile| [profile.default? ? "#{profile.name} (default)" : profile.name, profile.handle] },
                            {},
                            class: "select select-sm select-bordered",
                            data: { testid: "output-type-select" } %>
          </div>

          <p class="text-sm text-base-content/60" data-audio-recorder-target="status">&nbsp;</p>

          <p class="text-xs text-base-content/50">🔒 Private to your workspace · nothing is shared</p>

          <%= form.submit "Create document", class: "btn btn-ghost btn-sm", data: { "audio-recorder-target": "submitButton" } %>

          <input type="file"
                 name="recording_session[original_audio]"
                 class="hidden"
                 data-audio-recorder-target="recordInput">
        <% end %>
      </div>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
        <%= render "activity", recording_sessions: @recording_sessions %>

        <aside class="space-y-3">
          <h2 class="text-lg font-semibold">Output types</h2>
          <ul class="rounded-box border border-base-300 bg-base-100">
            <% @transformer_profiles.each do |profile| %>
              <li class="flex items-center justify-between gap-3 border-t border-base-300 p-3 first:border-t-0">
                <span class="truncate text-sm font-medium"><%= profile.name %></span>
                <% if profile.default? %>
                  <span class="shrink-0 text-xs text-base-content/50">★ Default</span>
                <% end %>
              </li>
            <% end %>
          </ul>
          <p class="text-xs text-base-content/50">Output types decide how your recording is turned into a document.</p>
        </aside>
      </div>
    <% end %>
  </div>
</section>
