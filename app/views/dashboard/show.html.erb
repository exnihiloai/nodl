<% content_for :title, t("dashboard.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("dashboard.meta_description") %>" />
<% end %>

<section class="bg-base-200 py-10">
  <% if @workspace %>
    <%= turbo_stream_from @workspace, :dashboard %>
  <% end %>

  <div class="container mx-auto max-w-5xl px-4 space-y-10">
    <% unless @workspace %>
      <div class="rounded-box border border-base-300 bg-base-100 p-8 text-center">
        <h1 class="text-2xl font-bold"><%= t("dashboard.no_workspace.heading") %></h1>
        <p class="mt-2 text-base-content/70"><%= t("dashboard.no_workspace.body") %></p>
      </div>
    <% else %>
      <% first_run = @recording_sessions.none? %>

      <%= render "record_hero",
                 recording_limit_reached: @recording_limit_reached,
                 recording_session: @recording_session,
                 transformer_profiles: @transformer_profiles %>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
        <%= render "activity", recording_sessions: @recording_sessions %>

        <aside class="space-y-3" data-testid="formats-panel">
          <div class="flex items-baseline justify-between">
            <h2 class="text-lg font-semibold"><%= t("dashboard.formats") %></h2>
            <% if @format_limit_reached %>
              <span class="text-xs text-base-content/50" data-testid="format-limit-reached"><%= t("dashboard.limits.formats_reached", limit: PlanLimits::MAX_FORMATS) %></span>
            <% else %>
              <%= link_to t("dashboard.new_format"), new_transformer_profile_path, class: "btn btn-ghost btn-xs", data: { testid: "new-format-button" } %>
            <% end %>
          </div>
          <ul class="rounded-box border border-base-300 bg-base-100">
            <% @transformer_profiles.each do |profile| %>
              <li class="flex items-center justify-between gap-3 border-t border-base-300 p-3 first:border-t-0" data-testid="format-item">
                <span class="truncate text-sm font-medium">
                  <%= link_to profile.name, transformer_profile_path(profile), class: "hover:underline" %>
                </span>
                <div class="flex shrink-0 items-center gap-2">
                  <% if profile.default? %>
                    <span class="text-xs text-base-content/50"><%= t("dashboard.default_badge") %></span>
                  <% end %>
                  <span class="dropdown dropdown-end">
                    <label tabindex="0" class="btn btn-ghost btn-xs" data-testid="format-menu-button" aria-label="<%= t("dashboard.format_actions") %>">⋯</label>
                    <ul tabindex="0" class="dropdown-content menu z-10 w-32 rounded-box border border-base-300 bg-base-100 p-1 shadow">
                      <li>
                        <%= link_to edit_transformer_profile_path(profile), class: "flex items-center gap-2" do %>
                          <%= icon "square-pen", class: "size-4" %>
                          <%= t("dashboard.edit") %>
                        <% end %>
                      </li>
                      <% unless profile.default? %>
                        <li>
                          <%= button_to transformer_profile_path(profile), method: :delete,
                                class: "flex items-center gap-2 text-error", data: { turbo_confirm: t("dashboard.delete_format_confirm") } do %>
                            <%= icon "trash-2", class: "size-4" %>
                            <%= t("dashboard.delete") %>
                          <% end %>
                        </li>
                      <% end %>
                    </ul>
                  </span>
                </div>
              </li>
            <% end %>
          </ul>
        </aside>
      </div>
    <% end %>
  </div>
</section>
