<% content_for :title, "Dashboard - Nodl" %>
<% content_for :head do %>
  <meta name="description" content="Speak a thought and get a clean, structured document back." />
<% end %>

<section class="bg-base-200 py-10">
  <% if @workspace %>
    <%= turbo_stream_from @workspace, :dashboard %>
  <% end %>

  <div class="container mx-auto max-w-5xl px-4 space-y-10">
    <% unless @workspace %>
      <div class="rounded-box border border-base-300 bg-base-100 p-8 text-center">
        <h1 class="text-2xl font-bold">No workspace assigned</h1>
        <p class="mt-2 text-base-content/70">Ask an administrator to add you to a workspace to start recording.</p>
      </div>
    <% else %>
      <% first_run = @recording_sessions.none? %>

      <div class="rounded-box border border-base-300 bg-base-100 px-6 py-10 text-center shadow-sm" data-testid="record-hero">
        <%= form_with model: @recording_session,
                      url: recording_sessions_path,
                      local: true,
                      multipart: true,
                      class: "flex flex-col items-center gap-4",
                      data: {
                        controller: "audio-recorder",
                        testid: "recording-form",
                        "audio-recorder-create-url-value": recording_sessions_path,
                        "audio-recorder-worklet-url-value": asset_path("audio_pcm_worklet.js")
                      } do |form| %>
          <%= form.hidden_field :source_kind, value: "upload", data: { "audio-recorder-target": "sourceKind" } %>

          <div class="relative isolate flex flex-wrap items-center justify-center gap-3">
            <span data-audio-recorder-target="aura" data-testid="recording-aura" class="voice-aura pointer-events-none absolute left-1/2 top-1/2 -z-10 hidden h-44 w-44" aria-hidden="true"></span>
            <%= form.button type: "button",
                            class: "btn btn-bouncy btn-primary btn-lg gap-2",
                            data: { "audio-recorder-target": "recordButton", action: "audio-recorder#start", testid: "record-button" } do %>
              <span class="text-lg" aria-hidden="true">●</span> Record
            <% end %>
            <button type="button" class="btn btn-outline hidden" data-audio-recorder-target="stopButton" data-action="audio-recorder#stop" data-testid="stop-recording-button" disabled>Stop</button>
            <span class="font-mono text-sm text-base-content/60 hidden" data-audio-recorder-target="timer" data-testid="recording-timer">00:00</span>
          </div>

          <div class="flex flex-col items-center gap-4" data-audio-recorder-target="options">
            <label class="cursor-pointer text-sm text-base-content/60 hover:text-base-content hover:underline">
              or upload audio
              <%= form.file_field :original_audio,
                                  accept: "audio/*,video/webm,video/mp4",
                                  class: "hidden",
                                  data: {
                                    "audio-recorder-target": "uploadInput",
                                    action: "change->audio-recorder#useUpload",
                                    testid: "audio-upload-input"
                                  } %>
            </label>

            <div class="flex flex-wrap items-center justify-center gap-2 text-sm">
              <%= form.select :transformer_handle,
                              @transformer_profiles.map { |profile| [profile.default? ? "#{profile.name} (default)" : profile.name, profile.handle] },
                              {},
                              class: "select select-sm select-bordered",
                              data: { testid: "output-type-select" } %>
            </div>

            <%= form.submit "Create document", class: "hidden", data: { "audio-recorder-target": "submitButton", testid: "create-document-button" } %>
          </div>

          <p class="text-sm text-base-content/60" data-audio-recorder-target="status">&nbsp;</p>

          <div class="hidden w-full max-w-2xl" data-audio-recorder-target="livePanelSlot">
            <section id="live_transcript_panel" class="rounded-box border border-base-300 bg-base-100 p-4 text-left shadow-sm" data-testid="live-transcript-panel">
              <div id="live_transcript_status">
                <div class="flex items-center justify-between gap-3">
                  <h2 class="text-sm font-semibold">Transcript</h2>
                  <span class="badge badge-warning badge-sm">Preview</span>
                </div>
                <p class="mt-1 text-xs text-base-content/60">Preview while recording — the final transcript will be cleaner.</p>
              </div>
              <div id="live_transcript_segments" class="mt-4 max-h-72 overflow-y-auto rounded-box bg-base-200 p-4">
                <p class="text-sm text-base-content/60" data-live-placeholder>Your live transcript will appear here as you speak.</p>
              </div>
            </section>
          </div>

          <p class="flex items-center justify-center gap-1 text-xs text-base-content/50">
            <%= icon("lock", class: "size-3.5") %>
            <span>Private to your workspace. Nothing is shared</span>
          </p>

          <input type="file"
                 name="recording_session[original_audio]"
                 class="hidden"
                 data-audio-recorder-target="recordInput"
                 data-testid="recorded-audio-input">
        <% end %>
      </div>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
        <%= render "activity", recording_sessions: @recording_sessions %>

        <aside class="space-y-3" data-testid="output-types-panel">
          <h2 class="text-lg font-semibold">Output types</h2>
          <ul class="rounded-box border border-base-300 bg-base-100">
            <% @transformer_profiles.each do |profile| %>
              <li class="flex items-center justify-between gap-3 border-t border-base-300 p-3 first:border-t-0">
                <span class="truncate text-sm font-medium"><%= profile.name %></span>
                <% if profile.default? %>
                  <span class="shrink-0 text-xs text-base-content/50">★ Default</span>
                <% end %>
              </li>
            <% end %>
          </ul>
          <p class="text-xs text-base-content/50">Output types decide how your recording is turned into a document.</p>
        </aside>
      </div>
    <% end %>
  </div>
</section>
