<div id="dashboard_record_hero" class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm" data-testid="record-hero">
  <% if recording_limit_reached %>
    <div class="space-y-3 text-center" data-testid="recording-limit-reached">
      <h1 class="text-2xl font-bold"><%= t("dashboard.start_heading") %></h1>
      <div class="alert alert-warning"><%= t("dashboard.limits.recordings_reached", limit: PlanLimits::MAX_RECORDINGS) %></div>
    </div>
  <% else %>
    <%= form_with model: recording_session,
                  url: recording_sessions_path,
                  local: true,
                  multipart: true,
                  class: "flex flex-col gap-6",
                  data: {
                    controller: "audio-recorder",
                    testid: "recording-form",
                    "audio-recorder-create-url-value": recording_sessions_path,
                    "audio-recorder-worklet-url-value": asset_path("audio_pcm_worklet.js"),
                    "audio-recorder-max-duration-seconds-value": PlanLimits.max_recording_duration_seconds,
                    "audio-recorder-duration-limit-text-value": t("dashboard.recorder.duration_limit"),
                    "audio-recorder-unsupported-text-value": t("dashboard.recorder.unsupported"),
                    "audio-recorder-start-error-text-value": t("dashboard.recorder.start_error"),
                    "audio-recorder-uploading-text-value": t("dashboard.recorder.uploading"),
                    "audio-recorder-session-error-text-value": t("dashboard.recorder.session_error"),
                    "audio-recorder-transcript-label-value": t("dashboard.transcript"),
                    "audio-recorder-listening-text-value": t("dashboard.listening"),
                    "audio-recorder-finalize-error-text-value": t("dashboard.recorder.finalize_error"),
                    "audio-recorder-preview-stopped-text-value": t("dashboard.recorder.preview_stopped"),
                    "audio-recorder-wake-lock-unavailable-text-value": t("dashboard.recorder.wake_lock_unavailable"),
                    "audio-recorder-interrupted-saving-text-value": t("dashboard.recorder.interrupted_saving"),
                    "audio-recorder-interrupted-no-audio-text-value": t("dashboard.recorder.interrupted_no_audio")
                  } do |form| %>
      <%= form.hidden_field :source_kind, value: "upload", data: { "audio-recorder-target": "sourceKind" } %>
      <%= form.hidden_field :time_zone, data: { "audio-recorder-target": "timeZone" } %>

      <h1 class="text-2xl font-bold"><%= t("dashboard.start_heading") %></h1>

      <div class="mx-auto flex w-full max-w-md flex-col gap-6">
        <div class="flex flex-col gap-2">
          <label class="text-sm text-base-content/60"><%= t("dashboard.turn_recording_into") %></label>
          <%= form.select :transformer_handle,
                          transformer_profiles.map { |profile| [profile.default? ? t("dashboard.default_suffix", name: profile.name) : profile.name, profile.handle] },
                          {},
                          class: "select select-bordered w-full",
                          data: { testid: "output-type-select" } %>
        </div>

        <div class="flex gap-3">
          <div class="flex flex-1 items-center gap-2">
            <%= form.button type: "button",
                            class: "btn btn-bouncy btn-primary flex-1 gap-2",
                            data: { "audio-recorder-target": "recordButton", action: "audio-recorder#start", testid: "record-button" } do %>
              <span aria-hidden="true">●</span> <%= t("dashboard.record") %>
            <% end %>
            <button type="button" class="btn btn-outline hidden flex-1" data-audio-recorder-target="stopButton" data-action="audio-recorder#stop" data-testid="stop-recording-button" disabled><%= t("dashboard.stop") %></button>
            <span class="hidden font-mono text-sm text-base-content/60" data-audio-recorder-target="timer" data-testid="recording-timer">00:00</span>
          </div>

          <div class="flex-1" data-audio-recorder-target="options">
            <label class="btn w-full cursor-pointer">
              <%= t("dashboard.upload_audio") %>
              <%= form.file_field :original_audio,
                                  accept: "audio/*,video/webm,video/mp4",
                                  class: "hidden",
                                  data: {
                                    "audio-recorder-target": "uploadInput",
                                    action: "change->audio-recorder#useUpload",
                                    testid: "audio-upload-input"
                                  } %>
            </label>
          </div>
        </div>
      </div>

      <%= form.submit t("dashboard.create_document"), class: "hidden", data: { "audio-recorder-target": "submitButton", testid: "create-document-button" } %>

      <p class="text-sm text-base-content/60" data-audio-recorder-target="status">&nbsp;</p>

      <div class="hidden w-full" data-audio-recorder-target="livePanelSlot">
        <div class="voice-stage" data-audio-recorder-target="stage">
          <span class="voice-aura" data-testid="recording-aura" aria-hidden="true"></span>
          <section id="live_transcript_panel" class="voice-stage__panel rounded-box border border-base-300 bg-base-100 p-4 text-left shadow-sm" data-testid="live-transcript-panel">
            <div id="live_transcript_status">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-sm font-semibold"><%= t("dashboard.transcript") %></h2>
              </div>
            </div>
            <div id="live_transcript_segments" class="mt-4 max-h-72 overflow-y-auto rounded-box bg-base-200 p-4">
              <p class="text-sm italic text-base-content/60" data-live-placeholder><%= t("dashboard.listening") %></p>
            </div>
          </section>
        </div>
      </div>

      <p class="flex items-center justify-center gap-1 text-xs text-base-content/50">
        <%= icon("lock", class: "size-3.5") %>
        <span><%= t("dashboard.privacy_note") %></span>
      </p>

      <input type="file"
             name="recording_session[original_audio]"
             class="hidden"
             data-audio-recorder-target="recordInput"
             data-testid="recorded-audio-input">
    <% end %>
  <% end %>
</div>
