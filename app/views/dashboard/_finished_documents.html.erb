<section id="dashboard_finished_documents" class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm">
  <div class="mb-4 flex items-center justify-between gap-3">
    <h2 class="text-xl font-semibold">Finished documents</h2>
    <span class="badge badge-outline"><%= documents.size %> recent</span>
  </div>
  <% if documents.any? %>
    <div class="space-y-3">
      <% documents.each do |document| %>
        <article class="rounded-box border border-base-300 p-4">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h3 class="font-medium"><%= document.title %></h3>
              <p class="text-sm text-base-content/60"><%= document.transformer_handle %> · <%= l(document.generated_at, format: :short) %></p>
            </div>
            <%= link_to "Open document", document_path(document), class: "btn btn-sm btn-primary" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="text-base-content/70">Generated documents will appear here after processing completes.</p>
  <% end %>
</section>
