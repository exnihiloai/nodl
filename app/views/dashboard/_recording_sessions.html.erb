<section id="dashboard_recording_sessions" class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm">
  <div class="mb-4 flex items-center justify-between gap-3">
    <h2 class="text-xl font-semibold">Recording sessions</h2>
    <span class="badge badge-outline"><%= recording_sessions.size %> recent</span>
  </div>
  <% if recording_sessions.any? %>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Session</th>
            <th>Status</th>
            <th>Transformer</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% recording_sessions.each do |session| %>
            <tr id="<%= dom_id(session, :dashboard_row) %>">
              <td>
                <div class="font-medium"><%= session.title %></div>
                <div class="text-xs text-base-content/60"><%= l(session.created_at, format: :short) %></div>
              </td>
              <td><span class="badge <%= session.completed? ? "badge-success" : session.failed? ? "badge-error" : "badge-warning" %>"><%= session.status.humanize %></span></td>
              <td><%= session.transformer_handle %></td>
              <td class="text-right"><%= link_to "Open", recording_session_path(session), class: "btn btn-sm btn-outline" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-base-content/70">No recording sessions yet.</p>
  <% end %>
</section>
