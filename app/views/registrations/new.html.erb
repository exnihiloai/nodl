<% content_for :title, t("registrations_view.new.title") %>
<% content_for :head do %>
  <meta name="description" content="<%= t("registrations_view.new.meta_description") %>" />
<% end %>

<section class="bg-gradient-to-br from-base-200 via-base-100 to-base-200 py-20">
  <div class="container mx-auto px-4 max-w-5xl flex flex-col lg:flex-row items-center gap-10">
    <aside class="w-full lg:w-5/12 space-y-6 text-center lg:text-left">
      <span class="badge badge-primary badge-lg gap-2"><%= t("registrations_view.new.aside.badge") %></span>
      <h1 class="text-3xl font-semibold"><%= t("registrations_view.new.aside.heading") %></h1>
      <p class="text-base-content/70">
        <%= t("registrations_view.new.aside.body") %>
      </p>
      <ul class="space-y-3 text-sm text-base-content/70">
        <li><%= t("registrations_view.new.aside.item_1") %></li>
        <li><%= t("registrations_view.new.aside.item_2") %></li>
        <li><%= t("registrations_view.new.aside.item_3") %></li>
      </ul>
    </aside>

    <div class="card bg-base-100 shadow-2xl w-full lg:w-7/12">
      <div class="card-body space-y-6">
        <div class="text-center">
          <p class="text-base-content/70"><%= t("registrations_view.new.lead") %></p>
        </div>

        <%= form_with url: register_path, class: "space-y-8" do |f| %>
          <div class="space-y-1">
            <%= f.email_field :email, id: "email", class: "input input-bordered w-full h-12", required: true, placeholder: t("registrations_view.new.email_placeholder"), value: @form["email"] %>
          </div>

          <div class="space-y-1">
            <%= f.email_field :email_confirm, id: "email_confirm", class: "input input-bordered w-full h-12", required: true, placeholder: t("registrations_view.new.email_confirm_placeholder"), value: @form["email_confirm"] %>
          </div>

          <div class="space-y-1">
            <%= render "shared/password_field", f:, field: :password, id: "password", class: "input input-bordered w-full h-12", required: true, minlength: 8, placeholder: t("registrations_view.new.password_placeholder") %>
          </div>

          <div class="space-y-1">
            <%= render "shared/password_field", f:, field: :password_confirm, id: "password_confirm", class: "input input-bordered w-full h-12", required: true, minlength: 8, placeholder: t("registrations_view.new.password_confirm_placeholder") %>
          </div>

          <div class="pt-2">
            <%= f.submit t("registrations_view.new.create_account"), class: "btn btn-primary w-full h-12 text-base font-semibold", data: { testid: "register-btn" } %>
          </div>
        <% end %>

        <div class="text-center text-sm">
          <%= t("registrations_view.new.already_have_account") %>
          <%= link_to t("registrations_view.new.sign_in"), login_path, class: "link link-primary" %>
        </div>
      </div>
    </div>
  </div>
</section>
