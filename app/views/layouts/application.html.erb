<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-theme="light">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Nodl" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Nodl">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "daisyui", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-base-200 text-base-content min-h-screen flex flex-col" data-controller="theme bouncy">
    <%= user_signed_in? ? render("shared/logged_in_nav") : render("shared/logged_out_nav") %>

    <main class="flex-1">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <footer class="border-t border-base-300 bg-base-100/90 backdrop-blur">
      <div class="container mx-auto px-4 py-6">
        <div class="flex flex-col sm:flex-row justify-between gap-4 text-sm text-base-content/70">
          <div><%= t("footer.copyright", year: Time.current.year) %></div>
          <div class="flex flex-wrap gap-4">
            <%= link_to t("footer.about"), about_path, class: "link link-hover" %>
            <%= link_to t("footer.pricing"), user_signed_in? ? payments_path : root_path(anchor: "pricing"), class: "link link-hover" %>
            <%= link_to t("footer.demo"), try_now_path, class: "link link-hover" %>
            <% LegalPage::SLUGS.each do |slug| %>
              <%= legal_page_link(slug) %>
            <% end %>
          </div>
        </div>
      </div>
    </footer>

    <%# Styled replacement for the browser's native confirm() dialog. Turbo is
        pointed at this modal for every `data-turbo-confirm` action. %>
    <dialog data-controller="confirm-modal" data-confirm-modal-target="dialog" class="modal">
      <div class="modal-box">
        <h3 class="text-lg font-bold" data-confirm-modal-target="title"><%= t("confirm_modal.title") %></h3>
        <p class="py-4" data-confirm-modal-target="message"></p>
        <div class="modal-action">
          <form method="dialog" class="flex gap-2">
            <button value="cancel" class="btn btn-ghost" data-confirm-modal-target="cancel"><%= t("confirm_modal.cancel") %></button>
            <button value="confirm" class="btn btn-error" data-confirm-modal-target="accept"><%= t("confirm_modal.confirm") %></button>
          </form>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button value="cancel" aria-label="<%= t("confirm_modal.close") %>"><%= t("confirm_modal.close") %></button>
      </form>
    </dialog>
  </body>
</html>
