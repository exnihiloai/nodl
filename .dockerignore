# Keep Docker build context small and prevent local-only files from entering images.

.git
.gitignore
.dockerignore

# OS/editor artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Environment and local secrets
.env
.env.*
config/master.key
config/credentials/*.key

# Local-only directories that must never enter an image.
# private/ is the reserved home for repo-private secrets and a companion repo.
# Keep ALL of private/ out by default, but allow the operator-specific content
# production can mount or bake in: legal pages, marketing views/locales, and
# private initializers. Secrets (.env, notify.env) and heavy test fixtures
# (test-data/, external/, internal/) stay excluded because they are direct
# children matched by `private/*` and are never re-included below.
private/*
!private/legal
!private/initializers
!private/locales
!private/locales/**
!private/views
!private/views/**
# Guard: never let stray OS artifacts back in via the negations above.
private/legal/.DS_Store
private/initializers/**/.DS_Store
work
test
doc

# Runtime output
log/*
tmp/*
storage/*
coverage
test/reports
.playwright-mcp

# Local dependency caches
.bundle
vendor/bundle

# Generated assets and local skill outputs
public/assets
public/packs
public/packs-test
.claude/agents
.codex/skills
CLAUDE.md
SKILL.md
